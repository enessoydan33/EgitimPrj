<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EgitimPrj</title>
    <script type="importmap"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EgitimPrj.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        bool isLoggedIn = Context.Session.GetString("IsLoggedIn") == "true";
        bool isTeacherLoggedIn = Context.Session.GetString("IsTeacherLoggedIn") == "true";
        bool isParentLoggedIn = Context.Session.GetString("IsParentLoggedIn") == "true";
        string? userName = Context.Session.GetString("Name");
        string? userId = Context.Session.GetString("UserId");
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-gradient">
            <div class="container-fluid">
                @{
                    var brandController = isTeacherLoggedIn ? "Teacher" : "Dashboard";
                    var brandAction = isTeacherLoggedIn ? "TeacherPanel" : (isParentLoggedIn ? "ParentSummary" : "Index");
                }
                <a class="navbar-brand fw-bold text-white" asp-action="@brandAction" asp-controller="@brandController">CoMentor</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @if (isTeacherLoggedIn)
                    {
                        <!-- Sadece öğretmen giriş yaptıysa: yalnızca Öğretmen Paneli -->
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a asp-controller="Teacher" asp-action="TeacherPanel" class="nav-link text-white">
                                    <i class="bi bi-person-workspace me-2"></i>Öğretmen Paneli
                                </a>
                            </li>
                        </ul>
                    }
                    else if (isLoggedIn)
                    {
                        <!-- Öğrenci giriş yaptıysa: Dashboard menüleri -->
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-white">
                                    <i class="bi bi-house-door-fill me-2"></i>Ana Sayfa
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="AIWork" class="nav-link text-white">
                                    <i class="bi bi-stars me-2"></i>AI Çalışma
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Lessons" class="nav-link text-white">
                                    <i class="bi bi-journal-text me-2"></i>Dersler
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="ParentSummary" class="nav-link text-white">
                                    <i class="bi bi-people-fill me-2"></i>Veli Özeti
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="ExamTracking" class="nav-link text-white">
                                    <i class="bi bi-graph-up-arrow me-2"></i>Deneme Takibi
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Schedule" class="nav-link text-white">
                                    <i class="bi bi-calendar-check me-2"></i>Takvim
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Appointments" class="nav-link text-white">
                                    <i class="bi bi-calendar2-event me-2"></i>Randevu
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Leaderboard" class="nav-link text-white">
                                    <i class="bi bi-trophy-fill me-2"></i>Liderlik
                                </a>
                            </li>
                        </ul>
                    }
                    else if (isParentLoggedIn)
                    {
                        <!-- Veli giriş yaptıysa -->
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="ParentSummary" class="nav-link text-white">
                                    <i class="bi bi-people-fill me-2"></i>Veli Bilgilendirme
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="ParentPanel" asp-action="Messages" class="nav-link text-white">
                                    <i class="bi bi-envelope-paper me-2"></i>Mesajlar
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="ParentPanel" asp-action="Appointments" class="nav-link text-white">
                                    <i class="bi bi-calendar-week me-2"></i>Etüt ve randevu
                                </a>
                            </li>
                        </ul>
                    }
                <div class="ms-auto">
                    @if (isLoggedIn || isTeacherLoggedIn || isParentLoggedIn)
                    {
                        <div class="d-flex align-items-center">
                            <div class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>
                                    Hesabım
                                    @if (!string.IsNullOrEmpty(userId))
                                    {
                                        <span class="ms-1 small text-light">(#@userId)</span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-action="UpdatePassword" asp-controller="User"><i class="bi bi-gear me-2"></i>Şifre Değiştir</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        @if (isTeacherLoggedIn)
                                        {
                                            <a class="dropdown-item text-danger" asp-controller="Teacher" asp-action="Logout">
                                                <i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap
                                            </a>
                                        }
                                        else if (isParentLoggedIn)
                                        {
                                            <a class="dropdown-item text-danger" asp-controller="Parent" asp-action="Logout">
                                                <i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="dropdown-item text-danger" asp-controller="User" asp-action="Logout">
                                                <i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap
                                            </a>
                                        }
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <a asp-controller="User" asp-action="Index" class="btn btn-outline-light">Giriş Yap</a>
                            <a asp-controller="User" asp-action="Register" class="btn btn-light text-dark">Kayıt Ol</a>
                            <a asp-controller="Parent" asp-action="Login" class="btn btn-outline-light">Veli Girişi</a>
                            <a asp-controller="Teacher" asp-action="Login" class="btn btn-outline-light">Öğretmen</a>
                        </div>
                    }
                    @RenderSection("Styles", required: false)

                </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - EgitimPrj - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
