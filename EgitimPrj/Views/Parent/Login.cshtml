@model LoginViewModel
@{
    ViewData["Title"] = "Veli Girişi";
}

<div class="container-fluid px-3 py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-6">
            <div class="login-card glass-card rounded-4 p-4 p-md-5 shadow-lg">
                <div class="text-center mb-4">
                    <div class="login-icon mb-3">
                        <i class="bi bi-people-fill text-primary" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Veli Paneli</h2>
                    <p class="text-muted">Veli hesabınızla giriş yapın</p>
                </div>

                <form method="post" asp-action="Login" asp-controller="Parent" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control border-start-0"
                                   autocomplete="off"
                                   data-lpignore="true"
                                   data-form-type="other"
                                   placeholder="veli@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control border-start-0"
                                   autocomplete="new-password"
                                   data-lpignore="true"
                                   data-form-type="other"
                                   placeholder="Şifrenizi girin" />

                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('Password', 'parentPasswordToggle')">
                                <i class="bi bi-eye" id="parentPasswordToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-grid mb-2">
                        <button type="submit" class="btn btn-gradient btn-lg btn-pill">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Veli Girişi
                        </button>
                    </div>

                    <div class="text-center mt-3 text-muted small">
                        Giriş yaptıktan sonra ödev ve randevu ekranlarına erişebilirsiniz.
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}

