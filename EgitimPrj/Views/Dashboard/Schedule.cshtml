@{
    ViewData["Title"] = "Ders Programı";
}

<div class="sched-page fade-in-up pt-4">

    @* Ajax istekleri için AntiForgeryToken (Create/Update/Delete Schedule) *@
    <div style="display:none">
        @Html.AntiForgeryToken()
    </div>

    <!-- ===== HEADER ===== -->
    <div class="modern-page-header header-schedule mb-4">
        <div class="modern-header-content">
            <div class="modern-header-icon">
                <i class="bi bi-calendar-week-fill"></i>
            </div>
            <div class="modern-header-text">
                <h1>Haftalık Ders Programı</h1>
                <p>AI ile oluşturulan ve manuel eklenen etütlerin tam takvimi</p>
            </div>
        </div>
        <div class="modern-header-actions d-flex gap-2 align-items-center">
            <a asp-action="AIProgramHazirlama" asp-controller="Dashboard"
               class="btn btn-sm btn-ai-gradient px-3 py-2">
                <i class="bi bi-robot me-1"></i> AI ile Yenile
            </a>
        </div>
        <div class="modern-header-decoration"></div>
    </div>

    <!-- ===== ANA GRID ===== -->
    <div class="row g-4 align-items-start">

        <!-- SOL: İstatistikler + Ekleme Formu -->
        <div class="col-xl-3 col-lg-4">
            <div class="stats-mini" id="statsBlock">
                <div class="stat-mini-item">
                    <i class="bi bi-clock-history text-primary"></i>
                    <div>
                        <div class="stat-mini-val" id="statTotalHours">-</div>
                        <div class="stat-mini-label">Haftalık Saat</div>
                    </div>
                </div>
                <div class="stat-mini-item">
                    <i class="bi bi-journal-bookmark text-success"></i>
                    <div>
                        <div class="stat-mini-val" id="statTotalItems">-</div>
                        <div class="stat-mini-label">Toplam Etüt</div>
                    </div>
                </div>
                <div class="stat-mini-item">
                    <i class="bi bi-calendar-check text-warning"></i>
                    <div>
                        <div class="stat-mini-val" id="statActiveDays">-</div>
                        <div class="stat-mini-label">Aktif Gün</div>
                    </div>
                </div>
            </div>

            <!-- Manuel Ders Ekleme Formu -->
            <div class="add-card mt-3">
                <div class="add-card-header">
                    <div class="icon-box-primary"><i class="bi bi-plus-circle"></i></div>
                    <div>
                        <h6 class="fw-bold mb-0">Ders Ekle</h6>
                        <small class="text-muted" style="font-size:.72rem">Manuel etüt ekleyin</small>
                    </div>
                </div>
                <div class="add-card-body">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Ders</label>
                        <select id="addSubject" class="form-select-modern w-100"></select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Gün</label>
                        <select id="addDay" class="form-select-modern w-100">
                            <option value="1">Pazartesi</option>
                            <option value="2">Salı</option>
                            <option value="3">Çarşamba</option>
                            <option value="4">Perşembe</option>
                            <option value="5">Cuma</option>
                            <option value="6">Cumartesi</option>
                            <option value="0">Pazar</option>
                        </select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Saat Aralığı</label>
                        <select id="addTimeSlot" class="form-select-modern w-100"></select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Konu (Opsiyonel)</label>
                        <input type="text" id="addTopic" class="form-control-modern w-100" placeholder="Örn: Türev, Paragraf...">
                    </div>
                    <button class="btn btn-add-schedule w-100" onclick="addNewLesson()">
                        <i class="bi bi-plus-lg me-1"></i> Ekle
                    </button>
                </div>
            </div>
        </div>

        <!-- SAĞ: Takvim -->
        <div class="col-xl-9 col-lg-8">
            <div class="calendar-card shadow-soft">
                <div class="calendar-toolbar">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-calendar3 text-primary fs-5"></i>
                        <h5 class="fw-bold mb-0 text-dark">Haftalık Takvim</h5>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="toggleView('grid')" id="btnGridView">
                            <i class="bi bi-grid-3x3-gap"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="toggleView('list')" id="btnListView">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                </div>

                <!-- LOADING STATE -->
                <div id="calLoading" class="cal-loading">
                    <div class="spinner-border text-primary mb-2" role="status"></div>
                    <p class="text-muted small">Program yükleniyor...</p>
                </div>

                <!-- EMPTY STATE -->
                <div id="calEmpty" class="cal-empty d-none">
                    <i class="bi bi-calendar-x cal-empty-icon"></i>
                    <h5 class="fw-bold">Henüz Program Yok</h5>
                    <p class="text-muted">AI ile program oluşturun veya sol panelden manuel ekleyin.</p>
                    <a asp-action="AIProgramHazirlama" asp-controller="Dashboard"
                       class="btn btn-ai-gradient px-4 py-2">
                        <i class="bi bi-robot me-2"></i> AI ile Program Oluştur
                    </a>
                </div>

                <!-- TAKVİM GRID -->
                <div id="calGrid" class="d-none">
                    <!-- Gün Başlıkları -->
                    <div class="week-header" id="weekHeader"></div>
                    <!-- Saat satırları -->
                    <div class="week-body" id="weekBody"></div>
                </div>

                <!-- LİSTE GÖRÜNÜMÜ -->
                <div id="calList" class="d-none">
                    <div id="listContent"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== DÜZENLEME MODAL ===== -->
<div class="edit-modal-overlay" id="editModalOverlay" onclick="closeEditModal()">
    <div class="edit-modal" onclick="event.stopPropagation()">
        <div class="edit-modal-header">
            <div class="d-flex align-items-center gap-2">
                <div class="icon-box-primary"><i class="bi bi-pencil-square"></i></div>
                <h5 class="fw-bold mb-0">Dersi Düzenle</h5>
            </div>
            <button class="edit-modal-close" onclick="closeEditModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="edit-modal-body">
            <input type="hidden" id="editId">
            <div class="form-group-modern">
                <label class="form-label-modern">Ders</label>
                <select id="editSubject" class="form-select-modern w-100"></select>
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Gün</label>
                <select id="editDay" class="form-select-modern w-100">
                    <option value="1">Pazartesi</option>
                    <option value="2">Salı</option>
                    <option value="3">Çarşamba</option>
                    <option value="4">Perşembe</option>
                    <option value="5">Cuma</option>
                    <option value="6">Cumartesi</option>
                    <option value="0">Pazar</option>
                </select>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Başlangıç</label>
                        <input type="time" id="editStartTime" class="form-control-modern w-100">
                    </div>
                </div>
                <div class="col-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Bitiş</label>
                        <input type="time" id="editEndTime" class="form-control-modern w-100">
                    </div>
                </div>
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Konu</label>
                <input type="text" id="editTopic" class="form-control-modern w-100" placeholder="Konu giriniz...">
            </div>
        </div>
        <div class="edit-modal-footer">
            <button class="btn btn-outline-danger btn-sm px-3" onclick="deleteFromModal()">
                <i class="bi bi-trash3 me-1"></i> Sil
            </button>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="closeEditModal()">İptal</button>
                <button class="btn btn-add-schedule btn-sm px-4" onclick="saveEdit()">
                    <i class="bi bi-check-lg me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== TOAST BİLDİRİM ===== -->
<div class="sched-toast" id="schedToast">
    <i class="bi" id="toastIcon"></i>
    <span id="toastMsg"></span>
</div>

@section Styles {
<style>
    :root {
        --sched-primary: #6366f1;
        --sched-success: #22c55e;
        --sched-warning: #f59e0b;
        --sched-radius: 20px;
        --sched-shadow: 0 8px 30px rgba(0,0,0,0.06);
    }

    .sched-page { padding-bottom: 3rem; }

    .fade-in-up { animation: fadeInUp 0.5s ease-out; }
    @@keyframes fadeInUp { from { opacity:0; transform:translateY(18px);} to { opacity:1; transform:none;} }

    /* ---- AI buton ---- */
    .btn-ai-gradient {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff; border: none; border-radius: 10px;
        font-weight: 600; font-size: .85rem;
        transition: filter .25s, transform .2s;
    }
    .btn-ai-gradient:hover { filter:brightness(1.1); transform:translateY(-1px); color:#fff; }


    /* ---- Sol Kart ---- */
    .add-card {
        background: #fff;
        border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .add-card-header {
        display: flex; align-items: center; gap: .75rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }
    .add-card-body { padding: 1.25rem 1.5rem; }

    .icon-box-primary {
        width: 44px; height: 44px; flex-shrink: 0;
        background: #e0e7ff; color: #4f46e5;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
    }

    .form-group-modern { margin-bottom: 1rem; }
    .form-label-modern {
        font-size: .78rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        color: #64748b; display: block; margin-bottom: .4rem;
    }
    .form-control-modern, .form-select-modern {
        border: 2px solid #e2e8f0; border-radius: 10px;
        padding: .6rem .9rem; font-size: .9rem;
        color: #1e293b; background: #f8fafc;
        transition: border-color .25s, box-shadow .25s;
    }
    .form-control-modern:focus, .form-select-modern:focus {
        border-color: #6366f1; background: #fff;
        box-shadow: 0 0 0 3px rgba(99,102,241,.15); outline: none;
    }

    .btn-add-schedule {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        color: #fff; border: none; border-radius: 10px;
        padding: .7rem 1rem; font-weight: 600;
        transition: filter .25s, transform .2s;
    }
    .btn-add-schedule:hover { filter:brightness(1.08); transform:translateY(-1px); color:#fff; }

    /* ---- Stats Mini ---- */
    .stats-mini {
        background: #fff; border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0; padding: .75rem 1rem;
        display: flex; flex-direction: column; gap: .5rem;
    }
    .stat-mini-item {
        display: flex; align-items: center; gap: .75rem;
        padding: .5rem .75rem; border-radius: 12px;
        background: #f8fafc;
    }
    .stat-mini-item i { font-size: 1.3rem; }
    .stat-mini-val { font-size: 1.1rem; font-weight: 800; color: #1e293b; line-height: 1; }
    .stat-mini-label { font-size: .72rem; color: #94a3b8; }

    /* ---- Takvim Kart ---- */
    .calendar-card {
        background: #fff; border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0; overflow: hidden;
    }
    .calendar-toolbar {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }

    /* Loading / Empty */
    .cal-loading, .cal-empty {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 4rem 2rem; text-align: center;
    }
    .cal-empty-icon { font-size: 4rem; color: #cbd5e1; margin-bottom: 1rem; }

    /* ===== HAFTALIK GRID ===== */
    .week-header {
        display: grid;
        grid-template-columns: 56px repeat(7, 1fr);
        border-bottom: 2px solid #f1f5f9;
        background: #f8fafc;
        position: sticky; top: 0; z-index: 5;
    }
    .week-header-time { /* koseli */ }
    .week-header-day {
        padding: .75rem .4rem;
        text-align: center;
        border-left: 1px solid #f1f5f9;
    }
    .week-header-day .day-name {
        font-size: .72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px; color: #94a3b8;
    }
    .week-header-day .day-date {
        font-size: 1.05rem; font-weight: 800; color: #1e293b;
    }
    .week-header-day.today .day-date {
        background: #6366f1; color: #fff;
        border-radius: 50%; width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto;
    }

    .week-body { overflow-y: auto; max-height: 600px; }
    .week-row {
        display: grid;
        grid-template-columns: 56px repeat(7, 1fr);
        min-height: 58px;
        border-bottom: 1px solid #f8fafc;
    }
    .week-row:hover { background: rgba(99,102,241,.02); }
    .week-time-label {
        font-size: .7rem; font-weight: 600; color: #94a3b8;
        display: flex; align-items: flex-start; justify-content: center;
        padding: .4rem .2rem 0;
        border-right: 1px solid #f1f5f9;
    }
    .week-cell {
        border-left: 1px solid #f8fafc;
        padding: 2px 4px;
        position: relative;
        transition: background .15s;
    }
    .week-cell:hover { background: rgba(99,102,241,.04); cursor: pointer; }

    /* Etüt bloğu */
    .cal-event {
        border-radius: 8px;
        padding: .35rem .55rem;
        margin-bottom: 2px;
        font-size: .75rem;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        position: relative;
        transition: filter .2s, transform .2s;
        overflow: hidden;
    }
    .cal-event:hover { filter: brightness(1.08); transform: translateY(-1px); }
    .cal-event .ev-time { font-size: .67rem; opacity: .85; font-weight: 500; }
    .cal-event .ev-title { line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cal-event .ev-del {
        position: absolute; top: 3px; right: 4px;
        width: 16px; height: 16px; border-radius: 50%;
        background: rgba(0,0,0,.25); color: #fff;
        display: none; align-items: center; justify-content: center;
        font-size: .6rem; cursor: pointer;
    }
    .cal-event:hover .ev-del { display: flex; }
    .cal-event.ai-event { box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .cal-event.ai-event::before {
        content: '✦';
        position: absolute; bottom: 3px; right: 5px;
        font-size: .6rem; opacity: .7;
    }

    /* ===== LİSTE GÖRÜNÜMÜ ===== */
    .list-day-block { padding: .75rem 1.5rem 1rem; border-bottom: 1px solid #f8fafc; }
    .list-day-title {
        font-size: .78rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: .8px;
        color: #94a3b8; margin-bottom: .6rem;
    }
    .list-event-item {
        display: flex; align-items: center; gap: .75rem;
        background: #f8fafc; border-radius: 12px;
        padding: .65rem 1rem; margin-bottom: .5rem;
        border-left: 4px solid #cbd5e1;
        transition: transform .2s, background .2s;
        position: relative;
    }
    .list-event-item:hover { background: #f1f5f9; transform: translateX(4px); }
    .list-event-dot {
        width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .list-ev-time { font-size: .78rem; color: #64748b; font-weight: 600; white-space: nowrap; min-width: 80px; }
    .list-ev-name { font-weight: 700; color: #1e293b; font-size: .9rem; }
    .list-ev-topic { font-size: .8rem; color: #64748b; }
    .list-ev-del {
        margin-left: auto; width: 26px; height: 26px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        background: rgba(239,68,68,.1); color: #ef4444;
        cursor: pointer; opacity: 0; transition: opacity .2s;
        font-size: .75rem;
    }
    .list-event-item:hover .list-ev-del { opacity: 1; }
    .list-ev-del:hover { background: #ef4444; color: #fff; }

    .shadow-soft { box-shadow: 0 8px 30px rgba(0,0,0,.05); }

    /* Scroll bar */
    .week-body::-webkit-scrollbar { width: 5px; }
    .week-body::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius:10px; }

    /* ===== EDIT MODAL ===== */
    .edit-modal-overlay {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(15,23,42,.45); backdrop-filter: blur(6px);
        display: none; align-items: center; justify-content: center;
        animation: fadeIn .2s ease;
    }
    .edit-modal-overlay.active { display: flex; }
    .edit-modal {
        background: #fff; border-radius: 20px; width: 100%; max-width: 480px;
        box-shadow: 0 25px 60px rgba(0,0,0,.18);
        animation: modalSlideUp .3s ease;
        overflow: hidden;
    }
    @@keyframes modalSlideUp { from { opacity:0; transform:translateY(30px);} to { opacity:1; transform:none;} }
    @@keyframes fadeIn { from { opacity:0;} to { opacity:1;} }
    .edit-modal-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }
    .edit-modal-close {
        width: 36px; height: 36px; border-radius: 10px; border: none;
        background: #f1f5f9; color: #64748b; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: all .2s;
    }
    .edit-modal-close:hover { background: #ef4444; color: #fff; }
    .edit-modal-body { padding: 1.5rem; }
    .edit-modal-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1rem 1.5rem; border-top: 1px solid #f1f5f9;
        background: #fafbfc;
    }

    /* ===== TOAST ===== */
    .sched-toast {
        position: fixed; bottom: 2rem; right: 2rem; z-index: 10000;
        background: #1e293b; color: #fff; padding: .75rem 1.25rem;
        border-radius: 12px; font-size: .88rem; font-weight: 600;
        display: flex; align-items: center; gap: .5rem;
        box-shadow: 0 8px 30px rgba(0,0,0,.2);
        transform: translateY(100px); opacity: 0;
        transition: all .35s cubic-bezier(.4,0,.2,1);
    }
    .sched-toast.show { transform: translateY(0); opacity: 1; }
    .sched-toast.toast-success { background: #059669; }
    .sched-toast.toast-error { background: #dc2626; }

    /* ===== LIST EDIT BUTTON ===== */
    .list-ev-edit {
        width: 26px; height: 26px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: rgba(99,102,241,.1); color: #6366f1;
        cursor: pointer; opacity: 0; transition: opacity .2s;
        font-size: .75rem; margin-left: auto;
    }
    .list-event-item:hover .list-ev-edit { opacity: 1; }
    .list-ev-edit:hover { background: #6366f1; color: #fff; }
</style>
}

@section Scripts {
<script>
window.AppPages.Schedule.init();
</script>
}
