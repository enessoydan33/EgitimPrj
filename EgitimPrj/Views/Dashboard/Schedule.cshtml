@{
    ViewData["Title"] = "Ders Programı";
}

<div class="sched-page fade-in-up">

    @* Ajax istekleri için AntiForgeryToken (Create/Update/Delete Schedule) *@
    <div style="display:none">
        @Html.AntiForgeryToken()
    </div>

    <!-- ===== HEADER ===== -->
    <div class="modern-page-header header-schedule mb-4">
        <div class="modern-header-content">
            <div class="modern-header-icon">
                <i class="bi bi-calendar-week-fill"></i>
            </div>
            <div class="modern-header-text">
                <h1>Haftalık Ders Programı</h1>
                <p>AI ile oluşturulan ve manuel eklenen etütlerin tam takvimi</p>
            </div>
        </div>
        <div class="modern-header-actions d-flex gap-2 align-items-center">
            <a asp-action="AIProgramHazirlama" asp-controller="Dashboard"
               class="btn btn-sm btn-ai-gradient px-3 py-2">
                <i class="bi bi-robot me-1"></i> AI ile Yenile
            </a>
        </div>
        <div class="modern-header-decoration"></div>
    </div>

    <!-- ===== ANA GRID ===== -->
    <div class="row g-4 align-items-start">

        <!-- SOL: İstatistikler + Ekleme Formu -->
        <div class="col-xl-3 col-lg-4">
            <div class="stats-mini" id="statsBlock">
                <div class="stat-mini-item">
                    <i class="bi bi-clock-history text-primary"></i>
                    <div>
                        <div class="stat-mini-val" id="statTotalHours">-</div>
                        <div class="stat-mini-label">Haftalık Saat</div>
                    </div>
                </div>
                <div class="stat-mini-item">
                    <i class="bi bi-journal-bookmark text-success"></i>
                    <div>
                        <div class="stat-mini-val" id="statTotalItems">-</div>
                        <div class="stat-mini-label">Toplam Etüt</div>
                    </div>
                </div>
                <div class="stat-mini-item">
                    <i class="bi bi-calendar-check text-warning"></i>
                    <div>
                        <div class="stat-mini-val" id="statActiveDays">-</div>
                        <div class="stat-mini-label">Aktif Gün</div>
                    </div>
                </div>
            </div>

            <!-- Manuel Ders Ekleme Formu -->
            <div class="add-card mt-3">
                <div class="add-card-header">
                    <div class="icon-box-primary"><i class="bi bi-plus-circle"></i></div>
                    <div>
                        <h6 class="fw-bold mb-0">Ders Ekle</h6>
                        <small class="text-muted" style="font-size:.72rem">Manuel etüt ekleyin</small>
                    </div>
                </div>
                <div class="add-card-body">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Ders</label>
                        <select id="addSubject" class="form-select-modern w-100"></select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Gün</label>
                        <select id="addDay" class="form-select-modern w-100">
                            <option value="1">Pazartesi</option>
                            <option value="2">Salı</option>
                            <option value="3">Çarşamba</option>
                            <option value="4">Perşembe</option>
                            <option value="5">Cuma</option>
                            <option value="6">Cumartesi</option>
                            <option value="0">Pazar</option>
                        </select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Saat Aralığı</label>
                        <select id="addTimeSlot" class="form-select-modern w-100"></select>
                    </div>
                    <div class="form-group-modern">
                        <label class="form-label-modern">Konu (Opsiyonel)</label>
                        <input type="text" id="addTopic" class="form-control-modern w-100" placeholder="Örn: Türev, Paragraf...">
                    </div>
                    <button class="btn btn-add-schedule w-100" onclick="addNewLesson()">
                        <i class="bi bi-plus-lg me-1"></i> Ekle
                    </button>
                </div>
            </div>
        </div>

        <!-- SAĞ: Takvim -->
        <div class="col-xl-9 col-lg-8">
            <div class="calendar-card shadow-soft">
                <div class="calendar-toolbar">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-calendar3 text-primary fs-5"></i>
                        <h5 class="fw-bold mb-0 text-dark">Haftalık Takvim</h5>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="toggleView('grid')" id="btnGridView">
                            <i class="bi bi-grid-3x3-gap"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="toggleView('list')" id="btnListView">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                </div>

                <!-- LOADING STATE -->
                <div id="calLoading" class="cal-loading">
                    <div class="spinner-border text-primary mb-2" role="status"></div>
                    <p class="text-muted small">Program yükleniyor...</p>
                </div>

                <!-- EMPTY STATE -->
                <div id="calEmpty" class="cal-empty d-none">
                    <i class="bi bi-calendar-x cal-empty-icon"></i>
                    <h5 class="fw-bold">Henüz Program Yok</h5>
                    <p class="text-muted">AI ile program oluşturun veya sol panelden manuel ekleyin.</p>
                    <a asp-action="AIProgramHazirlama" asp-controller="Dashboard"
                       class="btn btn-ai-gradient px-4 py-2">
                        <i class="bi bi-robot me-2"></i> AI ile Program Oluştur
                    </a>
                </div>

                <!-- TAKVİM GRID -->
                <div id="calGrid" class="d-none">
                    <!-- Gün Başlıkları -->
                    <div class="week-header" id="weekHeader"></div>
                    <!-- Saat satırları -->
                    <div class="week-body" id="weekBody"></div>
                </div>

                <!-- LİSTE GÖRÜNÜMÜ -->
                <div id="calList" class="d-none">
                    <div id="listContent"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== DÜZENLEME MODAL ===== -->
<div class="edit-modal-overlay" id="editModalOverlay" onclick="closeEditModal()">
    <div class="edit-modal" onclick="event.stopPropagation()">
        <div class="edit-modal-header">
            <div class="d-flex align-items-center gap-2">
                <div class="icon-box-primary"><i class="bi bi-pencil-square"></i></div>
                <h5 class="fw-bold mb-0">Dersi Düzenle</h5>
            </div>
            <button class="edit-modal-close" onclick="closeEditModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="edit-modal-body">
            <input type="hidden" id="editId">
            <div class="form-group-modern">
                <label class="form-label-modern">Ders</label>
                <select id="editSubject" class="form-select-modern w-100"></select>
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Gün</label>
                <select id="editDay" class="form-select-modern w-100">
                    <option value="1">Pazartesi</option>
                    <option value="2">Salı</option>
                    <option value="3">Çarşamba</option>
                    <option value="4">Perşembe</option>
                    <option value="5">Cuma</option>
                    <option value="6">Cumartesi</option>
                    <option value="0">Pazar</option>
                </select>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Başlangıç</label>
                        <input type="time" id="editStartTime" class="form-control-modern w-100">
                    </div>
                </div>
                <div class="col-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">Bitiş</label>
                        <input type="time" id="editEndTime" class="form-control-modern w-100">
                    </div>
                </div>
            </div>
            <div class="form-group-modern">
                <label class="form-label-modern">Konu</label>
                <input type="text" id="editTopic" class="form-control-modern w-100" placeholder="Konu giriniz...">
            </div>
        </div>
        <div class="edit-modal-footer">
            <button class="btn btn-outline-danger btn-sm px-3" onclick="deleteFromModal()">
                <i class="bi bi-trash3 me-1"></i> Sil
            </button>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="closeEditModal()">İptal</button>
                <button class="btn btn-add-schedule btn-sm px-4" onclick="saveEdit()">
                    <i class="bi bi-check-lg me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== TOAST BİLDİRİM ===== -->
<div class="sched-toast" id="schedToast">
    <i class="bi" id="toastIcon"></i>
    <span id="toastMsg"></span>
</div>

@section Styles {
<style>
    :root {
        --sched-primary: #6366f1;
        --sched-success: #22c55e;
        --sched-warning: #f59e0b;
        --sched-radius: 20px;
        --sched-shadow: 0 8px 30px rgba(0,0,0,0.06);
    }

    .sched-page { padding-bottom: 3rem; }

    .fade-in-up { animation: fadeInUp 0.5s ease-out; }
    @@keyframes fadeInUp { from { opacity:0; transform:translateY(18px);} to { opacity:1; transform:none;} }

    /* ---- AI buton ---- */
    .btn-ai-gradient {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff; border: none; border-radius: 10px;
        font-weight: 600; font-size: .85rem;
        transition: filter .25s, transform .2s;
    }
    .btn-ai-gradient:hover { filter:brightness(1.1); transform:translateY(-1px); color:#fff; }

    /* ---- Sol Kart ---- */
    .add-card {
        background: #fff;
        border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .add-card-header {
        display: flex; align-items: center; gap: .75rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }
    .add-card-body { padding: 1.25rem 1.5rem; }

    .icon-box-primary {
        width: 44px; height: 44px; flex-shrink: 0;
        background: #e0e7ff; color: #4f46e5;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
    }

    .form-group-modern { margin-bottom: 1rem; }
    .form-label-modern {
        font-size: .78rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        color: #64748b; display: block; margin-bottom: .4rem;
    }
    .form-control-modern, .form-select-modern {
        border: 2px solid #e2e8f0; border-radius: 10px;
        padding: .6rem .9rem; font-size: .9rem;
        color: #1e293b; background: #f8fafc;
        transition: border-color .25s, box-shadow .25s;
    }
    .form-control-modern:focus, .form-select-modern:focus {
        border-color: #6366f1; background: #fff;
        box-shadow: 0 0 0 3px rgba(99,102,241,.15); outline: none;
    }

    .btn-add-schedule {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        color: #fff; border: none; border-radius: 10px;
        padding: .7rem 1rem; font-weight: 600;
        transition: filter .25s, transform .2s;
    }
    .btn-add-schedule:hover { filter:brightness(1.08); transform:translateY(-1px); color:#fff; }

    /* ---- Stats Mini ---- */
    .stats-mini {
        background: #fff; border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0; padding: .75rem 1rem;
        display: flex; flex-direction: column; gap: .5rem;
    }
    .stat-mini-item {
        display: flex; align-items: center; gap: .75rem;
        padding: .5rem .75rem; border-radius: 12px;
        background: #f8fafc;
    }
    .stat-mini-item i { font-size: 1.3rem; }
    .stat-mini-val { font-size: 1.1rem; font-weight: 800; color: #1e293b; line-height: 1; }
    .stat-mini-label { font-size: .72rem; color: #94a3b8; }

    /* ---- Takvim Kart ---- */
    .calendar-card {
        background: #fff; border-radius: var(--sched-radius);
        border: 1px solid #e2e8f0; overflow: hidden;
    }
    .calendar-toolbar {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }

    /* Loading / Empty */
    .cal-loading, .cal-empty {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 4rem 2rem; text-align: center;
    }
    .cal-empty-icon { font-size: 4rem; color: #cbd5e1; margin-bottom: 1rem; }

    /* ===== HAFTALIK GRID ===== */
    .week-header {
        display: grid;
        grid-template-columns: 56px repeat(7, 1fr);
        border-bottom: 2px solid #f1f5f9;
        background: #f8fafc;
        position: sticky; top: 0; z-index: 5;
    }
    .week-header-time { /* koseli */ }
    .week-header-day {
        padding: .75rem .4rem;
        text-align: center;
        border-left: 1px solid #f1f5f9;
    }
    .week-header-day .day-name {
        font-size: .72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px; color: #94a3b8;
    }
    .week-header-day .day-date {
        font-size: 1.05rem; font-weight: 800; color: #1e293b;
    }
    .week-header-day.today .day-date {
        background: #6366f1; color: #fff;
        border-radius: 50%; width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto;
    }

    .week-body { overflow-y: auto; max-height: 600px; }
    .week-row {
        display: grid;
        grid-template-columns: 56px repeat(7, 1fr);
        min-height: 58px;
        border-bottom: 1px solid #f8fafc;
    }
    .week-row:hover { background: rgba(99,102,241,.02); }
    .week-time-label {
        font-size: .7rem; font-weight: 600; color: #94a3b8;
        display: flex; align-items: flex-start; justify-content: center;
        padding: .4rem .2rem 0;
        border-right: 1px solid #f1f5f9;
    }
    .week-cell {
        border-left: 1px solid #f8fafc;
        padding: 2px 4px;
        position: relative;
        transition: background .15s;
    }
    .week-cell:hover { background: rgba(99,102,241,.04); cursor: pointer; }

    /* Etüt bloğu */
    .cal-event {
        border-radius: 8px;
        padding: .35rem .55rem;
        margin-bottom: 2px;
        font-size: .75rem;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        position: relative;
        transition: filter .2s, transform .2s;
        overflow: hidden;
    }
    .cal-event:hover { filter: brightness(1.08); transform: translateY(-1px); }
    .cal-event .ev-time { font-size: .67rem; opacity: .85; font-weight: 500; }
    .cal-event .ev-title { line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cal-event .ev-del {
        position: absolute; top: 3px; right: 4px;
        width: 16px; height: 16px; border-radius: 50%;
        background: rgba(0,0,0,.25); color: #fff;
        display: none; align-items: center; justify-content: center;
        font-size: .6rem; cursor: pointer;
    }
    .cal-event:hover .ev-del { display: flex; }
    .cal-event.ai-event { box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .cal-event.ai-event::before {
        content: '✦';
        position: absolute; bottom: 3px; right: 5px;
        font-size: .6rem; opacity: .7;
    }

    /* ===== LİSTE GÖRÜNÜMÜ ===== */
    .list-day-block { padding: .75rem 1.5rem 1rem; border-bottom: 1px solid #f8fafc; }
    .list-day-title {
        font-size: .78rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: .8px;
        color: #94a3b8; margin-bottom: .6rem;
    }
    .list-event-item {
        display: flex; align-items: center; gap: .75rem;
        background: #f8fafc; border-radius: 12px;
        padding: .65rem 1rem; margin-bottom: .5rem;
        border-left: 4px solid #cbd5e1;
        transition: transform .2s, background .2s;
        position: relative;
    }
    .list-event-item:hover { background: #f1f5f9; transform: translateX(4px); }
    .list-event-dot {
        width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .list-ev-time { font-size: .78rem; color: #64748b; font-weight: 600; white-space: nowrap; min-width: 80px; }
    .list-ev-name { font-weight: 700; color: #1e293b; font-size: .9rem; }
    .list-ev-topic { font-size: .8rem; color: #64748b; }
    .list-ev-del {
        margin-left: auto; width: 26px; height: 26px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        background: rgba(239,68,68,.1); color: #ef4444;
        cursor: pointer; opacity: 0; transition: opacity .2s;
        font-size: .75rem;
    }
    .list-event-item:hover .list-ev-del { opacity: 1; }
    .list-ev-del:hover { background: #ef4444; color: #fff; }

    .shadow-soft { box-shadow: 0 8px 30px rgba(0,0,0,.05); }

    /* Scroll bar */
    .week-body::-webkit-scrollbar { width: 5px; }
    .week-body::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius:10px; }

    /* ===== EDIT MODAL ===== */
    .edit-modal-overlay {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(15,23,42,.45); backdrop-filter: blur(6px);
        display: none; align-items: center; justify-content: center;
        animation: fadeIn .2s ease;
    }
    .edit-modal-overlay.active { display: flex; }
    .edit-modal {
        background: #fff; border-radius: 20px; width: 100%; max-width: 480px;
        box-shadow: 0 25px 60px rgba(0,0,0,.18);
        animation: modalSlideUp .3s ease;
        overflow: hidden;
    }
    @@keyframes modalSlideUp { from { opacity:0; transform:translateY(30px);} to { opacity:1; transform:none;} }
    @@keyframes fadeIn { from { opacity:0;} to { opacity:1;} }
    .edit-modal-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8faff, #fff);
    }
    .edit-modal-close {
        width: 36px; height: 36px; border-radius: 10px; border: none;
        background: #f1f5f9; color: #64748b; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: all .2s;
    }
    .edit-modal-close:hover { background: #ef4444; color: #fff; }
    .edit-modal-body { padding: 1.5rem; }
    .edit-modal-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1rem 1.5rem; border-top: 1px solid #f1f5f9;
        background: #fafbfc;
    }

    /* ===== TOAST ===== */
    .sched-toast {
        position: fixed; bottom: 2rem; right: 2rem; z-index: 10000;
        background: #1e293b; color: #fff; padding: .75rem 1.25rem;
        border-radius: 12px; font-size: .88rem; font-weight: 600;
        display: flex; align-items: center; gap: .5rem;
        box-shadow: 0 8px 30px rgba(0,0,0,.2);
        transform: translateY(100px); opacity: 0;
        transition: all .35s cubic-bezier(.4,0,.2,1);
    }
    .sched-toast.show { transform: translateY(0); opacity: 1; }
    .sched-toast.toast-success { background: #059669; }
    .sched-toast.toast-error { background: #dc2626; }

    /* ===== LIST EDIT BUTTON ===== */
    .list-ev-edit {
        width: 26px; height: 26px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: rgba(99,102,241,.1); color: #6366f1;
        cursor: pointer; opacity: 0; transition: opacity .2s;
        font-size: .75rem; margin-left: auto;
    }
    .list-event-item:hover .list-ev-edit { opacity: 1; }
    .list-ev-edit:hover { background: #6366f1; color: #fff; }
</style>
}

@section Scripts {
<script>
const DAY_NAMES = ["Pazar","Pazartesi","Salı","Çarşamba","Perşembe","Cuma","Cumartesi"];
const ORDERED_DAYS = [1,2,3,4,5,6,0];
const START_HOUR = 7;
const END_HOUR = 23;

let subjectsMap = {};
let allScheduleData = [];
let currentView = 'grid';

// ===============================
// YARDIMCI FONKSIYONLAR
// ===============================
function hex2rgb(hex) {
    if (!hex) return '99,102,241';
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
}
function timeToMinutes(t) {
    if (!t) return 0;
    const [h,m] = t.substring(0,5).split(':').map(Number);
    return h * 60 + (m || 0);
}
function fmtTime(t) { return (t || '').substring(0,5); }

function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

// ===============================
// TOAST BİLDİRİM
// ===============================
function showToast(msg, type = 'success') {
    const el = document.getElementById('schedToast');
    const icon = document.getElementById('toastIcon');
    document.getElementById('toastMsg').textContent = msg;
    el.className = 'sched-toast toast-' + type;
    icon.className = 'bi ' + (type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill');
    setTimeout(() => el.classList.add('show'), 10);
    setTimeout(() => el.classList.remove('show'), 3000);
}

// ===============================
// ZAMAN ARALIĞI SEÇENEKLERİ (sol form)
// ===============================
function populateTimeSlots() {
    const sel = document.getElementById('addTimeSlot');
    if (!sel) return;
    sel.innerHTML = '';
    for (let h = 7; h < 23; h++) {
        const st = h.toString().padStart(2,'0') + ':00';
        const en = (h+1).toString().padStart(2,'0') + ':00';
        const opt = document.createElement('option');
        opt.value = `${st}|${en}`;
        opt.textContent = `${st} – ${en}`;
        sel.appendChild(opt);
    }
}

// ===============================
// DERSLERİ YÜKLE
// ===============================
async function loadSubjects() {
    try {
        const res = await fetch('/Exam/Subjects');
        if (!res.ok) throw new Error();
        const subjects = await res.json();

        // Her iki select'i de doldur (add + edit)
        const addSel = document.getElementById('addSubject');
        const editSel = document.getElementById('editSubject');
        if (addSel) addSel.innerHTML = '<option value="">Bir ders seçin...</option>';
        if (editSel) editSel.innerHTML = '<option value="">Bir ders seçin...</option>';

        subjects.forEach(s => {
            const id = s.id || s.Id;
            const name = s.name || s.Name;
            const color = s.colorHex || s.ColorHex || '#6366f1';
            subjectsMap[id] = { name, color };

            [addSel, editSel].forEach(sel => {
                if (!sel) return;
                const opt = document.createElement('option');
                opt.value = id;
                opt.textContent = name;
                sel.appendChild(opt);
            });
        });
    } catch(e) {
        console.warn('Dersler yüklenemedi', e);
    }
}

// ===============================
// PROGRAM VERİSİNİ YÜKLE
// ===============================
async function loadSchedule() {
    showLoader(true);
    try {
        const res = await fetch('/Pomodoro/WeeklySchedule');
        if (!res.ok) throw new Error(await res.text());
        const data = await res.json();

        const flat = [];
        (data || []).forEach(day => {
            const dayIdx = day.dayOfWeek ?? day.DayOfWeek;
            const schedules = day.schedules || day.Schedules || [];
            schedules.forEach(item => {
                flat.push({
                    id: item.id ?? item.Id,
                    subjectId: item.subjectId ?? item.SubjectId,
                    subjectName: item.subjectName ?? item.SubjectName ?? '',
                    subjectColor: item.subjectColorHex ?? item.SubjectColorHex ?? null,
                    dayOfWeek: item.dayOfWeek ?? item.DayOfWeek ?? dayIdx,
                    startTime: item.startTime ?? item.StartTime ?? '',
                    endTime: item.endTime ?? item.EndTime ?? '',
                    topic: item.topic ?? item.Topic ?? '',
                    isAI: false
                });
            });
        });

        allScheduleData = flat;
        renderCalendar();
        updateStats();
    } catch(e) {
        console.error(e);
        showLoader(false);
        document.getElementById('calEmpty').classList.remove('d-none');
    }
}

function showLoader(show) {
    document.getElementById('calLoading').classList.toggle('d-none', !show);
    document.getElementById('calGrid').classList.add('d-none');
    document.getElementById('calList').classList.add('d-none');
    document.getElementById('calEmpty').classList.add('d-none');
}

// ===============================
// TAKVİM / LİSTE RENDER
// ===============================
function renderCalendar() {
    showLoader(false);
    if (allScheduleData.length === 0) {
        document.getElementById('calEmpty').classList.remove('d-none');
        return;
    }
    if (currentView === 'grid') renderGrid();
    else renderList();
}

function toggleView(v) {
    currentView = v;
    document.getElementById('btnGridView').className = v === 'grid'
        ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-outline-primary';
    document.getElementById('btnListView').className = v === 'list'
        ? 'btn btn-sm btn-secondary' : 'btn btn-sm btn-outline-secondary';
    if (allScheduleData.length > 0) renderCalendar();
}

// --- GRID ---
function renderGrid() {
    document.getElementById('calGrid').classList.remove('d-none');
    document.getElementById('calList').classList.add('d-none');
    const today = new Date().getDay();

    const headerEl = document.getElementById('weekHeader');
    headerEl.innerHTML = '<div class="week-time-label" style="border-bottom:none"></div>';
    ORDERED_DAYS.forEach(d => {
        const isToday = d === today;
        const div = document.createElement('div');
        div.className = 'week-header-day' + (isToday ? ' today' : '');
        div.innerHTML = `
            <div class="day-name">${DAY_NAMES[d].substring(0,3).toUpperCase()}</div>
            <div class="day-date">${DAY_NAMES[d].substring(0,3)}</div>`;
        headerEl.appendChild(div);
    });

    const evMap = {};
    allScheduleData.forEach(ev => {
        const key = `${ev.dayOfWeek}`;
        if (!evMap[key]) evMap[key] = [];
        evMap[key].push(ev);
    });

    const bodyEl = document.getElementById('weekBody');
    bodyEl.innerHTML = '';

    for (let h = START_HOUR; h < END_HOUR; h++) {
        const row = document.createElement('div');
        row.className = 'week-row';
        const lbl = document.createElement('div');
        lbl.className = 'week-time-label';
        lbl.textContent = h.toString().padStart(2,'0') + ':00';
        row.appendChild(lbl);

        ORDERED_DAYS.forEach(dayIdx => {
            const cell = document.createElement('div');
            cell.className = 'week-cell';
            const dayEvents = (evMap[dayIdx] || []).filter(ev => {
                const evH = parseInt((ev.startTime || '').substring(0, 2));
                return evH === h;
            });

            dayEvents.forEach(ev => {
                const subj = subjectsMap[ev.subjectId] || { name: ev.subjectName || 'Etüt', color: '#6366f1' };
                const color = ev.subjectColor || subj.color || '#6366f1';
                const rgb = hex2rgb(color);
                const evEl = document.createElement('div');
                evEl.className = 'cal-event' + (ev.isAI ? ' ai-event' : '');
                evEl.style.background = `rgba(${rgb},.85)`;
                evEl.style.borderLeft = `3px solid rgba(${rgb},1)`;
                evEl.innerHTML = `
                    <div class="ev-time">${fmtTime(ev.startTime)}–${fmtTime(ev.endTime)}</div>
                    <div class="ev-title">${subj.name}</div>
                    ${ev.topic ? `<div class="ev-time">${ev.topic}</div>` : ''}
                    <div class="ev-del" onclick="deleteItem(event, ${ev.id})"><i class="bi bi-x"></i></div>`;
                // Tıklayınca düzenleme modalı aç
                evEl.addEventListener('click', (e) => {
                    if (e.target.closest('.ev-del')) return;
                    openEditModal(ev);
                });
                cell.appendChild(evEl);
            });

            row.appendChild(cell);
        });
        bodyEl.appendChild(row);
    }
}

// --- LİSTE ---
function renderList() {
    document.getElementById('calList').classList.remove('d-none');
    document.getElementById('calGrid').classList.add('d-none');

    const grouped = {};
    ORDERED_DAYS.forEach(d => grouped[d] = []);
    allScheduleData.forEach(ev => {
        if (grouped[ev.dayOfWeek] !== undefined) grouped[ev.dayOfWeek].push(ev);
    });

    let html = '';
    ORDERED_DAYS.forEach(dayIdx => {
        const items = grouped[dayIdx];
        if (!items || !items.length) return;
        items.sort((a,b) => (a.startTime||'').localeCompare(b.startTime||''));
        html += `<div class="list-day-block">
            <div class="list-day-title">${DAY_NAMES[dayIdx]}</div>`;
        items.forEach(ev => {
            const subj = subjectsMap[ev.subjectId] || { name: ev.subjectName || 'Etüt', color: '#6366f1' };
            const color = ev.subjectColor || subj.color || '#6366f1';
            html += `
            <div class="list-event-item" style="border-left-color:${color}" onclick="openEditModal(findEventById(${ev.id}))">
                <div class="list-event-dot" style="background:${color}"></div>
                <div class="list-ev-time">${fmtTime(ev.startTime)} – ${fmtTime(ev.endTime)}</div>
                <div>
                    <div class="list-ev-name">${subj.name}</div>
                    ${ev.topic ? `<div class="list-ev-topic">${ev.topic}</div>` : ''}
                </div>
                <div class="list-ev-edit" onclick="event.stopPropagation(); openEditModal(findEventById(${ev.id}))" title="Düzenle">
                    <i class="bi bi-pencil" style="font-size:11px"></i>
                </div>
                <div class="list-ev-del" onclick="event.stopPropagation(); deleteItem(event, ${ev.id})" title="Sil">
                    <i class="bi bi-x-lg" style="font-size:11px"></i>
                </div>
            </div>`;
        });
        html += '</div>';
    });

    document.getElementById('listContent').innerHTML = html ||
        '<div class="p-4 text-center text-muted">Program boş.</div>';
}

function findEventById(id) {
    return allScheduleData.find(e => e.id === id);
}

// ===============================
// İSTATİSTİK
// ===============================
function updateStats() {
    const totalItems = allScheduleData.length;
    let totalMinutes = 0;
    const activeDays = new Set();
    allScheduleData.forEach(ev => {
        totalMinutes += timeToMinutes(ev.endTime) - timeToMinutes(ev.startTime);
        activeDays.add(ev.dayOfWeek);
    });
    document.getElementById('statTotalItems').textContent = totalItems;
    document.getElementById('statTotalHours').textContent =
        (totalMinutes / 60).toFixed(1).replace('.0','') + ' sa';
    document.getElementById('statActiveDays').textContent = activeDays.size;
}

// ===============================
// YENİ DERS EKLE (Sol Panel Formu)
// ===============================
async function addNewLesson() {
    const subjectId = document.getElementById('addSubject').value;
    const dayOfWeek = parseInt(document.getElementById('addDay').value);
    const timeSlot = document.getElementById('addTimeSlot').value;
    const topic = document.getElementById('addTopic').value.trim();

    if (!subjectId) { showToast('Lütfen bir ders seçin.', 'error'); return; }
    if (!timeSlot) { showToast('Lütfen saat aralığı seçin.', 'error'); return; }

    const [startTime, endTime] = timeSlot.split('|');

    try {
        const res = await fetch('/Pomodoro/CreateSchedule', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify({
                subjectId: parseInt(subjectId),
                dayOfWeek,
                startTime,
                endTime,
                topic: topic || null
            })
        });
        if (res.ok) {
            showToast('Ders başarıyla eklendi!');
            document.getElementById('addTopic').value = '';
            await loadSchedule();
        } else {
            showToast('Eklenirken hata oluştu.', 'error');
        }
    } catch(ex) {
        console.error(ex);
        showToast('Bağlantı hatası!', 'error');
    }
}

// ===============================
// DÜZENLEME MODAL
// ===============================
function openEditModal(ev) {
    if (!ev) return;
    document.getElementById('editId').value = ev.id;
    document.getElementById('editSubject').value = ev.subjectId || '';
    document.getElementById('editDay').value = ev.dayOfWeek;
    document.getElementById('editStartTime').value = fmtTime(ev.startTime);
    document.getElementById('editEndTime').value = fmtTime(ev.endTime);
    document.getElementById('editTopic').value = ev.topic || '';
    document.getElementById('editModalOverlay').classList.add('active');
}

function closeEditModal() {
    document.getElementById('editModalOverlay').classList.remove('active');
}

async function saveEdit() {
    const id = document.getElementById('editId').value;
    const subjectId = parseInt(document.getElementById('editSubject').value);
    const dayOfWeek = parseInt(document.getElementById('editDay').value);
    const startTime = document.getElementById('editStartTime').value;
    const endTime = document.getElementById('editEndTime').value;
    const topic = document.getElementById('editTopic').value.trim();

    if (!subjectId) { showToast('Lütfen bir ders seçin.', 'error'); return; }
    if (!startTime || !endTime) { showToast('Saat aralığı boş olamaz.', 'error'); return; }

    try {
        const res = await fetch(`/Pomodoro/UpdateSchedule?scheduleId=${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify({ subjectId, dayOfWeek, startTime, endTime, topic: topic || null })
        });
        if (res.ok) {
            showToast('Ders güncellendi!');
            closeEditModal();
            await loadSchedule();
        } else {
            showToast('Güncellenirken hata oluştu.', 'error');
        }
    } catch(ex) {
        console.error(ex);
        showToast('Bağlantı hatası!', 'error');
    }
}

function deleteFromModal() {
    const id = document.getElementById('editId').value;
    if (!id) return;
    closeEditModal();
    deleteItem(new Event('click'), parseInt(id));
}

// ===============================
// SİL
// ===============================
async function deleteItem(e, id) {
    if (e && e.stopPropagation) e.stopPropagation();
    if (!confirm('Bu etüdü silmek istiyor musunuz?')) return;
    try {
        const res = await fetch(`/Pomodoro/DeleteSchedule?scheduleId=${id}`, {
            method: 'DELETE',
            headers: { 'RequestVerificationToken': getAntiForgeryToken() }
        });
        if (res.ok) {
            showToast('Ders silindi.');
            await loadSchedule();
        } else {
            showToast('Silinirken hata oluştu.', 'error');
        }
    } catch(ex) {
        console.error(ex);
        showToast('Bağlantı hatası!', 'error');
    }
}

// ===============================
// KLAVYE KISAYOLU (ESC ile modal kapat)
// ===============================
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeEditModal();
});

// ===============================
// INIT
// ===============================
populateTimeSlots();
toggleView('grid');
loadSubjects().then(() => loadSchedule());
</script>
}
