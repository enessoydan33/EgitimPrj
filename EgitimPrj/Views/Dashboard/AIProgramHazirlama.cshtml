            ],

            "Yabancı Dil": [
                "Kelime Bilgisi (Vocabulary)",
                "Dil Bilgisi (Tense’ler, Modals, Passive, Relative Clauses vb.)",
                "Cümle Tamamlama",
                "Paragraf Tamamlama",
                "Anlam Bütünlüğünü Bozan Cümle",
                "Çeviri (TR-EN / EN-TR vb.)",
                "Okuma Parçaları (Reading)",
                "Dialog / Duruma Uygun İfade"
            ],

            "Varsayılan": ["Konu 1", "Konu 2", "Konu 3", "Genel Tekrar", "Soru Çözümü", "Branş Denemesi", "Fasikül Çözümü"]
        };

        // Tüm ders listelerine "Deneme Çözümü" ekle (chip olarak).
        Object.keys(FALLBACK_TOPICS).forEach(k => {
            const arr = FALLBACK_TOPICS[k];
            if (!Array.isArray(arr)) return;
            if (!arr.includes("Deneme Çözümü")) arr.push("Deneme Çözümü");
        });

        // SS'deki "Ders Seçimi" kart sırası
        const COURSE_ORDER = [
            "Türkçe", "Matematik", "Fen Bilimleri", "Sosyal Bilimler", "AYT Matematik", "Fizik",
            "Kimya", "Biyoloji", "Edebiyat", "Tarih-1", "Coğrafya-1", "Tarih-2", "Coğrafya-2",
            "Felsefe Grubu", "Din Kültürü"
        ];
        function getCourseOrderIndex(courseName) {
            const n = (courseName || '').toLowerCase();
            for (let i = 0; i < COURSE_ORDER.length; i++) {
                const key = COURSE_ORDER[i];
                if (key && n.includes(key.toLowerCase())) return i;
            }
            return Number.MAX_SAFE_INTEGER;
        }

        function normalizeTurkish(s) {
            return (s || '')
                .toLowerCase()
                .replace(/[ğĞ]/g, 'g')
                .replace(/[üÜ]/g, 'u')
                .replace(/[şŞ]/g, 's')
                .replace(/[ıİ]/g, 'i')
                .replace(/[öÖ]/g, 'o')
                .replace(/[çÇ]/g, 'c');
        }

        function isAllowedCourseForSelection(courseName) {
            const n = normalizeTurkish(courseName);
            if (n.includes('yabanci') || n.includes('yabancı')) return false;

            return true; // Allows all others
        }

        let currentStep = 1;
        const hoursByDay = Object.fromEntries(DAYS.map(d => [d, []]));
        const selectedCourses = new Set();
        const topicsByCourse = {};
        const subjectIds = {}; // Backend Subject ID eşleşmeleri
        let activeDay = DAYS[0];

        const dayTabs = document.getElementById('dayTabs');
        const hoursGrid = document.getElementById('hoursGrid');
        const selHoursCount = document.getElementById('selHoursCount');
        const courseGrid = document.getElementById('courseGrid');
        const selCourseCount = document.getElementById('selCourseCount');
        const topicsWrap = document.getElementById('topicsWrap');
        const summary = document.getElementById('summary');
        const btnNext = document.getElementById('btnNext');
        const btnPrev = document.getElementById('btnPrev');
        const stepHint = document.getElementById('stepHint');
        const sb1 = document.getElementById('sb1');
        const sb2 = document.getElementById('sb2');
        const sb3 = document.getElementById('sb3');
        const sb4 = document.getElementById('sb4');
        const sl1 = document.getElementById('sl1');
        const sl2 = document.getElementById('sl2');
        const sl3 = document.getElementById('sl3');
        const sections = [null, 'step-1', 'step-2', 'step-3', 'step-4'];

        function timeLabel(h) { return String(h).padStart(2, '0') + ":00"; }
        function countAllHours() { return Object.values(hoursByDay).reduce((a, b) => a + b.length, 0); }
        function refreshHourSelectionUi() {
            setText('selHoursCount', countAllHours());
            renderHours();
            validateNext();
        }

        function renderDayTabs() {
            dayTabs.innerHTML = '';
            DAYS.forEach(d => {
                const li = document.createElement('li'); li.className = 'nav-item';
                const btn = document.createElement('button');
                btn.className = 'nav-link ' + (d === activeDay ? 'active bg-success text-white' : '');
                btn.style.borderRadius = '999px'; btn.textContent = d;
                btn.onclick = () => { activeDay = d; renderDayTabs(); renderHours(); };
                li.appendChild(btn); dayTabs.appendChild(li);
            });
        }
        function renderHours() {
            hoursGrid.innerHTML = '';
            HOURS.forEach(h => {
                const b = document.createElement('button');
                b.className = 'btn btn-light';
                if (hoursByDay[activeDay].includes(h)) b.classList.add('active');
                b.textContent = timeLabel(h);
                b.onclick = () => {
                    const arr = hoursByDay[activeDay];
                    const i = arr.indexOf(h);
                    if (i >= 0) arr.splice(i, 1); else arr.push(h);
                    arr.sort((a, b) => a - b);
                    refreshHourSelectionUi();
                };
                hoursGrid.appendChild(b);
            });
            setText('selHoursCount', countAllHours());
        }

        function selectAllHours() {
            hoursByDay[activeDay] = [...HOURS];
            refreshHourSelectionUi();
        }
        
        function clearAllHours() {
            hoursByDay[activeDay] = [];
            refreshHourSelectionUi();
        }
        
        function selectTimeRange(start, end) {
            const arr = hoursByDay[activeDay];
            HOURS.forEach(h => {
                if (h >= start && h <= end) {
                    if (!arr.includes(h)) arr.push(h);
                }
            });
            arr.sort((a, b) => a - b);
            refreshHourSelectionUi();
        }

        function renderCourses() {
            courseGrid.innerHTML = '';
            const orderedCourseNames = Object.keys(ALL_COURSES).sort((a, b) => {
                const ia = getCourseOrderIndex(a);
                const ib = getCourseOrderIndex(b);
                if (ia !== ib) return ia - ib;
                return (a || '').localeCompare((b || ''), 'tr', { sensitivity: 'base' });
            });
            orderedCourseNames.forEach(name => {
                const col = document.createElement('div'); col.className = 'col-12 col-sm-6 col-lg-4';
                const card = document.createElement('div'); card.className = 'course-card h-100';
                if (selectedCourses.has(name)) card.classList.add('active');
                card.innerHTML = `<i class="bi bi-journal-bookmark fs-4 text-warning"></i><div class="fw-semibold">${name}</div>`;
                card.onclick = () => {
                    if (selectedCourses.has(name)) selectedCourses.delete(name);
                    else selectedCourses.add(name);
                    renderCourses(); renderTopics();
                    setText('selCourseCount', selectedCourses.size); validateNext();
                };
                col.appendChild(card); courseGrid.appendChild(col);
            });
            setText('selCourseCount', selectedCourses.size);
        }

        function renderTopics() {
            topicsWrap.innerHTML = '';
            [...selectedCourses].forEach(course => {
                const box = document.createElement('div'); box.className = 'mb-4';
                box.innerHTML = `<div class="fw-bold mb-2">${course}</div>`;
                const row = document.createElement('div'); row.className = 'd-flex flex-wrap gap-2';
                (ALL_COURSES[course] || []).forEach(tp => {
                    const b = document.createElement('button'); b.className = 'chip'; b.textContent = tp;
                    const arr = topicsByCourse[course] || [];
                    if (arr.includes(tp)) b.classList.add('selected');
                    b.onclick = () => {
                        const cur = topicsByCourse[course] || [];
                        const i = cur.indexOf(tp);
                        if (i >= 0) cur.splice(i, 1); else cur.push(tp);
                        topicsByCourse[course] = cur; renderTopics(); validateNext();
                    };
                    row.appendChild(b);
                });
                box.appendChild(row); topicsWrap.appendChild(box);
            });
        }

        function renderSummary() {
            const hours = Object.entries(hoursByDay).filter(([, arr]) => arr.length)
                .map(([d, arr]) => `<li><strong>${d}</strong>: ${arr.map(timeLabel).join(', ')}</li>`).join('');
            const courses = [...selectedCourses].map(c => `<li><strong>${c}</strong>: ${(topicsByCourse[c] || []).join(', ') || ''}</li>`).join('');
            summary.innerHTML = `<ul>${hours || '<li>Seçim yok</li>'}</ul><ul>${courses || '<li>Seçim yok</li>'}</ul>`;
        }

        function showStep(n) {
            sections.forEach((id, idx) => { if (!id) return; document.getElementById(id).classList.toggle('d-none', idx !== n); });
            currentStep = n;
            if (sb1 && sb2 && sb3 && sb4) {
                [sb1, sb2, sb3, sb4].forEach((el, i) => el.className = 'step-badge ' + (i + 1 <= n ? 'step-active' : 'bg-light text-dark'));
            }
            if (sl1 && sl2 && sl3) {
                [sl1, sl2, sl3].forEach((el, i) => el.style.background = (i + 1 < n ? '#22c55e' : 'rgba(255,255,255,.4)'));
            }
            stepHint.textContent = n <= 3 ? `Adım ${n}/3` : 'Bitti';
            btnPrev.disabled = (n === 1);
            btnNext.textContent = (n === 3 ? 'Bitir' : n === 4 ? 'Yeniden Başla' : 'İleri ');
            validateNext();
            if (n === 4) renderSummary();
        }

        function validateNext() {
            let ok = false;
            if (currentStep === 1) ok = countAllHours() > 0;
            if (currentStep === 2) ok = selectedCourses.size > 0;
            if (currentStep === 3) ok = [...selectedCourses].every(c => (topicsByCourse[c] || []).length > 0);
            if (currentStep === 4) ok = true;
            btnNext.disabled = !ok;
        }

        btnNext.onclick = () => {
            if (currentStep === 3) { showStep(4); return; }
            if (currentStep === 4) { showStep(1); return; }
            showStep(currentStep + 1);
        };
        btnPrev.onclick = () => showStep(Math.max(1, currentStep - 1));

        const btnGenerateAI = document.getElementById('btnGenerateAI');
        const aiFeedback = document.getElementById('aiFeedback');

        btnGenerateAI.onclick = async () => {
            btnGenerateAI.disabled = true;
            aiFeedback.innerHTML = `
                <div class="d-flex flex-column align-items-center gap-2 py-3">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="text-muted fw-bold">
                        <i class="bi bi-robot me-1"></i> AI programınızı hazırlıyor, lütfen bekleyin...
                    </div>
                </div>`;

            const weeklyAvailability = [];
            Object.entries(hoursByDay).forEach(([dayName, hours]) => {
                if(hours.length > 0) {
                    const dayIdx = (DAYS.indexOf(dayName) + 1) % 7;
                    weeklyAvailability.push({
                        DayOfWeek: dayIdx,
                        TimeSlots: hours.sort((a,b)=>a-b).map(h => String(h).padStart(2, '0') + ":00")
                    });
                }
            });

            const subjectPreferences = [];
            selectedCourses.forEach(c => {
                subjectPreferences.push({
                    SubjectId: subjectIds[c] || 0,
                    SubjectName: c,
                    SelectedTopics: topicsByCourse[c] || []
                });
            });

            const payload = {
                TargetWeeklyHours: countAllHours(),
                WeeklyAvailability: weeklyAvailability,
                SubjectPreferences: subjectPreferences,
                ExamType: "TYT",
                WeakTopics: []
            };

            try {
                // Tek fetch: AI üret + Pomodoro'ya kaydet
                const result = await fetchJson('/api/StudyScheduleProxy/GenerateAndSave', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const saved = result.saved || result.Saved || 0;

                aiFeedback.innerHTML = `
                    <div class="text-success fw-bold fs-5">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        ${saved > 0 ? saved + ' etüt takvime eklendi!' : 'Program oluşturuldu!'}
                    </div>
                    <div class="text-muted small mt-1">Takvim sayfasına yönlendiriliyorsunuz...</div>`;

                setTimeout(() => {
                    window.location.href = '/Dashboard/Schedule';
                }, 2000);
            } catch(e) {
                console.error(e);
                aiFeedback.innerHTML = `
                    <div class="text-danger fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Hata: ${e.message}
                    </div>`;
                btnGenerateAI.disabled = false;
            }
        };

        // Arka uçtan dinamik ders listesini çek ve Fallback topics ekle
        function findFallbackTopicKey(courseName) {
            let matchedKey = "Varsayılan";
            const lowerName = (courseName || '').toLowerCase();
            for (const key of Object.keys(FALLBACK_TOPICS)) {
                if (key === "Varsayılan") continue;
                if (lowerName.includes(key.toLowerCase())) {
                    matchedKey = key;
                    break;
                }
            }
            return matchedKey;
        }

        async function initSubjects() {
            try {
                // Dersleri backend'in Subject API'sinden Exam Controller aracılığıyla alıyoruz
                const subjects = await fetchJson('/Exam/Subjects');
                
                if(subjects && subjects.length > 0) {
                    ALL_COURSES = {};
                    
                    subjects.forEach(s => {
                        const name = s.Name || s.name;
                        const id = s.Id || s.id;
                        if (!isAllowedCourseForSelection(name)) return;

                        const matchedKey = findFallbackTopicKey(name);
                        ALL_COURSES[name] = FALLBACK_TOPICS[matchedKey];
                        subjectIds[name] = id;
                    });
                }
            } catch (err) {
                console.error("Dersler backend'den alınırken hata oluştu, varsayılanlar yükleniyor.", err);
                // Bir sorun olursa basit fallback
                ALL_COURSES = {
                    "Türkçe": FALLBACK_TOPICS["Türkçe"],
                    "Matematik": FALLBACK_TOPICS["Matematik"],
                    "Fizik": FALLBACK_TOPICS["Fizik"],
                    "Kimya": FALLBACK_TOPICS["Kimya"]
                };
            }

            renderDayTabs(); renderHours(); renderCourses(); renderTopics(); showStep(1);
        }

        initSubjects();
    </script>
}
