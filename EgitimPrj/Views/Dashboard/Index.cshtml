@{
    ViewData["Title"] = "Ana Sayfa";
    var actionCards = new[]
    {
        new
        {
            CardClass = "ai-modern-card",
            Action = "AIWork",
            Controller = "Dashboard",
            Icon = "bi-robot",
            Badge = "Yeni",
            Title = "AI Ders Programı",
            Description = "Kişiselleştirilmiş AI destekli ders programı oluşturun",
            Features = new[] { "Akıllı zamanlama", "Kişisel öneriler", "Adaptif öğrenme" }
        },
        new
        {
            CardClass = "lessons-modern-card",
            Action = "Lessons",
            Controller = "Dashboard",
            Icon = "bi-book",
            Badge = "Aktif",
            Title = "Dersler",
            Description = "Kapsamlı ders içerikleri ve interaktif öğrenme",
            Features = new[] { "Video dersler", "Alıştırmalar", "İlerleme takibi" }
        },
        new
        {
            CardClass = "exam-modern-card",
            Action = "ExamTracking",
            Controller = "Dashboard",
            Icon = "bi-clipboard-data",
            Badge = "Analiz",
            Title = "Deneme Takibi",
            Description = "Sınav performansınızı takip edin ve analiz edin",
            Features = new[] { "Detaylı raporlar", "Performans analizi", "Gelişim takibi" }
        }
    };
}

<div class="dashboard-container">
    <!-- Hoş Geldiniz Bölümü -->
    <div class="modern-page-header header-welcome">
        <div class="modern-header-content">
            <div class="modern-header-icon">
                <i class="bi bi-house-door-fill"></i>
            </div>
            <div class="modern-header-text">
                <h1>Merhaba! 👋</h1>
                <p>Bugün de harika bir gün geçirelim!</p>
            </div>
        </div>
        <div class="modern-header-actions d-flex gap-3">
            <div class="welcome-badge streak-badge">
                <i class="bi bi-fire"></i>
                <span id="home-streak">-</span>
            </div>
            <div class="welcome-badge xp-badge">
                <i class="bi bi-star-fill"></i>
                <span id="home-total-xp">-</span>
            </div>
            <div class="welcome-badge achievement-badge">
                <i class="bi bi-trophy-fill"></i>
                <span id="home-earned-achievements">-</span>
            </div>
        </div>
        <div class="modern-header-decoration"></div>
    </div>

    <!-- Günlük Hedef -->
    <div class="daily-goal-section mb-5">
        <div class="row">
            <div class="col-12">
                <div class="daily-goal-card">
                    <h3 class="goal-title">Günlük Hedef</h3>
                    <div class="goal-progress">
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill" id="daily-goal-bar" style="width: 0%"></div>
                        </div>
                        <span class="progress-text" id="daily-goal-text">0/0</span>
                    </div>
                    <p class="goal-message" id="daily-goal-message">Yükleniyor...</p>
                </div>
            </div>
        </div>
    </div>


    <!-- Bugün Ne Yapmak İstiyorsun? -->
    <div class="section-title mb-4">
        <h2>Bugün ne yapmak istiyorsun?</h2>
    </div>

    <!-- Ana Kartlar -->
    <div class="row g-4 mb-5">
        @foreach (var card in actionCards)
        {
            <div class="col-lg-4 col-md-6">
                <div class="modern-card @card.CardClass" onclick="location.href='@Url.Action(card.Action, card.Controller)'">
                    <div class="card-header">
                        <div class="card-icon-wrapper">
                            <i class="bi @card.Icon"></i>
                        </div>
                        <div class="card-badge">
                            <span class="badge-text">@card.Badge</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">@card.Title</h3>
                        <p class="card-description">@card.Description</p>
                        <div class="card-features">
                            @foreach (var feature in card.Features)
                            {
                                <div class="feature-item">
                                    <i class="bi bi-check-circle"></i>
                                    <span>@feature</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="card-arrow">
                            <i class="bi bi-arrow-right"></i>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>

    <!-- Leaderboard ve Başarılar (Sekmeli) + Duyuru ve Ödevler -->
    <div class="row mt-5 align-items-stretch">
        <div class="col-lg-8 mb-4 mb-lg-0">
            <div class="leaderboard-widget glass-card p-0 h-100 d-flex flex-column">
                <div class="leaderboard-widget-header">
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="leaderboard-title">
                            <div class="leaderboard-icon"><i class="bi bi-trophy"></i></div>
                            <div>
                                <h3 class="mb-0">Sıralama ve Başarılar</h3>
                            </div>
                        </div>
                        <span class="badge bg-light text-dark" id="home-leaderboard-status">Yükleniyor...</span>
                    </div>
                </div>

                <!-- Tabs -->
                <div class="px-4 mt-3">
                    <ul class="nav nav-tabs" id="leaderboardTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="rankings-tab" data-bs-toggle="tab" data-bs-target="#rankings-pane" type="button" role="tab" aria-controls="rankings-pane" aria-selected="true">
                                <i class="bi bi-list-ol me-1"></i> Genel Sıralama
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="achievements-tab" data-bs-toggle="tab" data-bs-target="#achievements-pane" type="button" role="tab" aria-controls="achievements-pane" aria-selected="false">
                                <i class="bi bi-award me-1"></i> Başarılarım 
                                <span class="badge bg-secondary ms-1 rounded-pill" id="achievements-tab-count">0</span>
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="leaderboard-widget-body tab-content flex-grow-1 overflow-auto custom-scrollbar p-0" id="leaderboardTabsContent" style="max-height: 550px; min-height: 550px;">
                    <!-- Tab 1: Sıralama -->
                    <div class="tab-pane fade show active" id="rankings-pane" role="tabpanel" aria-labelledby="rankings-tab">
                        <div class="leaderboard-xp-grid" id="home-xp-grid">
                            <div class="leaderboard-xp-item">
                                <div class="label">Toplam XP</div>
                                <div class="value" id="home-xp-total">-</div>
                            </div>
                            <div class="leaderboard-xp-item">
                                <div class="label">Bugün XP</div>
                                <div class="value" id="home-xp-today">-</div>
                            </div>
                            <div class="leaderboard-xp-item">
                                <div class="label">Hafta XP</div>
                                <div class="value" id="home-xp-week">-</div>
                            </div>
                            <div class="leaderboard-xp-item">
                                <div class="label">Streak</div>
                                <div class="value" id="home-xp-streak">-</div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-borderless align-middle mb-0" id="home-leaderboard-table">
                                <thead>
                                    <tr class="text-muted small">
                                        <th style="width:64px;">#</th>
                                        <th>Ad</th>
                                        <th class="text-end">XP</th>
                                        <th class="text-end">Streak</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td colspan="4" class="text-muted">Yükleniyor...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab 2: Başarılar -->
                    <div class="tab-pane fade" id="achievements-pane" role="tabpanel" aria-labelledby="achievements-tab">
                        <div class="p-4">
                            <div class="achievements-grid" id="home-achievements-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem;">
                                <div class="text-muted small">Yükleniyor...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Duyuru ve Ödevler Widget -->
        <div class="col-lg-4">
            <div class="announcements-widget glass-card p-0 h-100 d-flex flex-column">
                <div class="leaderboard-widget-header">
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="leaderboard-title">
                            <div class="leaderboard-icon"><i class="bi bi-bell"></i></div>
                            <div>
                                <h3 class="mb-0 fs-5">Duyuru & Ödevler</h3>
                            </div>
                        </div>
                        <span class="badge bg-primary rounded-pill">3 Yeni</span>
                    </div>
                </div>

                <!-- Tabs -->
                <div class="px-3 mt-3">
                    <ul class="nav nav-tabs nav-justified" id="notificationTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active small py-2" id="announcements-tab" data-bs-toggle="tab" data-bs-target="#announcements-pane" type="button" role="tab">
                                <i class="bi bi-megaphone me-1"></i> Duyuru
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link small py-2" id="homeworks-tab" data-bs-toggle="tab" data-bs-target="#homeworks-pane" type="button" role="tab">
                                <i class="bi bi-journal-text me-1"></i> Ödev
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="tab-content flex-grow-1 p-3 overflow-auto custom-scrollbar" id="notificationTabsContent" style="max-height: 550px; min-height: 550px;">
                    <!-- Tab 1: Duyurular -->
                    <div class="tab-pane fade show active" id="announcements-pane" role="tabpanel">
                        <div class="d-flex flex-column gap-3" id="student-announcements-container">
                            <div class="text-muted small">Yükleniyor...</div>
                        </div>
                    </div>

                    <!-- Tab 2: Ödevler -->
                    <div class="tab-pane fade" id="homeworks-pane" role="tabpanel">
                        <div class="d-flex flex-column gap-3" id="student-homeworks-container">
                            <div class="text-muted small">Yükleniyor...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>





    <!-- Son Aktiviteler -->
    <div class="row mt-5">
        <div class="activity-section">
                <h3 class="activity-title">Son Aktiviteler</h3>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon">
                            <i class="bi bi-play-circle-fill"></i>
                        </div>
                        <div class="activity-content">
                            <h5>Matematik Dersi Tamamlandı</h5>
                            <p>İntegral konusu başarıyla tamamlandı</p>
                            <span class="activity-time">2 saat önce</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon">
                            <i class="bi bi-clipboard-check"></i>
                        </div>
                        <div class="activity-content">
                            <h5>Deneme Sınavı</h5>
                            <p>TYT Deneme Sınavı #15 tamamlandı - %78 başarı</p>
                            <span class="activity-time">1 gün önce</span>
                        </div>
                    </div>
                </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const setStatus = (text, cls = "bg-light text-dark") => {
        const el = document.getElementById('home-leaderboard-status');
        if (!el) return;
        el.className = `badge ${cls}`;
        el.textContent = text;
    };

    const fetchJson = window.AppUtils.fetchJson;
    const setText = (id, value) => window.AppUtils.setText(id, value);

    const setLoadError = (id, message = 'Yüklenemedi') => {
        const container = document.getElementById(id);
        if (!container) return;
        container.innerHTML = `<div class="text-danger small">${message}</div>`;
    };

    const safeLoad = async (label, task, onError) => {
        try {
            await task();
        } catch (err) {
            console.error(`${label} error`, err);
            if (typeof onError === 'function') onError(err);
        }
    };



    const renderXp = (data) => {
        const totalXp = data?.totalXp ?? data?.TotalXp ?? 0;
        const todayXp = data?.todayXp ?? data?.TodayXp ?? 0;
        const weekXp = data?.weekXp ?? data?.WeekXp ?? 0;

        setText('home-xp-total', totalXp);
        setText('home-xp-today', todayXp);
        setText('home-xp-week', weekXp);

        setText('home-total-xp', `${totalXp} XP`);
    };

    const renderLeaderboard = (data) => {
        const tbody = document.querySelector('#home-leaderboard-table tbody');
        if (!tbody) return;
        const rankings = data?.rankings || data?.Rankings || [];
        if (!rankings.length) {
            tbody.innerHTML = `<tr><td colspan="4" class="text-muted">Kayıt yok</td></tr>`;
            return;
        }
        tbody.innerHTML = rankings.slice(0, 10).map(item => {
            const rank = item.rank || item.Rank || '-';
            const name = item.name || item.Name || '';
            const surname = item.surname || item.Surname || '';
            const totalXp = item.totalXp || item.TotalXp || 0;
            const streak = item.currentStreak || item.CurrentStreak || 0;
            return `
                <tr class="leaderboard-row">
                    <td><span class="leaderboard-rank">${rank}</span></td>
                    <td>
                        <div class="fw-semibold">${name} ${surname}</div>
                    </td>
                    <td class="text-end fw-semibold">${totalXp}</td>
                    <td class="text-end"><span class="leaderboard-streak">${streak}</span></td>
                </tr>
            `;
        }).join('');
    };

    const renderAchievements = (data) => {
        const container = document.getElementById('home-achievements-container');
        if (!container) return;
        
        const achievements = Array.isArray(data)
            ? data
            : (data?.data || data?.items || data?.achievements || data?.Achievements || data?.$values || []);

        if (!achievements || achievements.length === 0) {
            container.innerHTML = `<div class="text-muted small p-3">Henüz başarı tanımı bulunamadı.</div>`;
            return;
        }

        const earnedCount = achievements.filter(a => 
            (a.isEarned === true) || (String(a.isEarned).toLowerCase() === 'true') || (a.IsEarned === true)
        ).length;
        setText('home-earned-achievements', earnedCount);
        setText('achievements-tab-count', earnedCount);

        container.innerHTML = achievements.map(a => {
            const name = a.name || a.Name || 'Başarı';
            const desc = a.description || a.Description || '';
            const icon = a.icon || a.Icon || 'bi-star';
            const color = a.badgeColor || a.BadgeColor || '#FFD700';
            const isEarned = (a.isEarned === true) || (String(a.isEarned).toLowerCase() === 'true') || (a.IsEarned === true);
            
            const cardStyle = isEarned 
                ? `border-top: 3px solid ${color};` 
                : `border-top: 3px solid #ccc; filter: grayscale(100%); opacity: 0.7;`;
            
            const iconColor = isEarned ? color : '#6c757d';

            return `
                <div class="achievement-card text-center p-3 glass-card" style="min-width: 140px; ${cardStyle}">
                    <div class="achievement-icon mb-2" style="font-size: 2rem; color: ${iconColor}">
                        <i class="bi ${icon}"></i>
                    </div>
                    <div class="fw-bold small mb-1 text-truncate" title="${name}">${name}</div>
                    <div class="text-muted x-small text-truncate" style="font-size: 0.75rem;" title="${desc}">${desc}</div>
                    ${!isEarned ? '<div class="mt-1"><i class="bi bi-lock-fill text-muted"></i></div>' : ''}
                </div>
            `;
        }).join('');
    };

    const normalizeAchievements = window.AppUtils.normalizeAchievements;
    
    const renderStreak = (streakData) => {
        const current = streakData.currentStreak ?? streakData.CurrentStreak ?? 0;
        const longest = streakData.longestStreak ?? streakData.LongestStreak ?? 0;
        const hasStudied = streakData.hasStudiedToday ?? streakData.HasStudiedToday ?? false;

        setText('home-streak', `${current} Gün`);
        setText('home-xp-streak', current);
        
        const streakContainer = document.querySelector('.streak-badge');
        if (streakContainer) {
            if (hasStudied) {
                streakContainer.classList.add('text-warning');
                streakContainer.title = "Bugün çalıştın!";
            } else {
                streakContainer.classList.remove('text-warning');
                streakContainer.title = "Bugün henüz çalışmadın.";
            }
        }
    };

    const renderStudentAnnouncements = (announcements) => {
        const container = document.getElementById('student-announcements-container');
        if (!container) return;
        
        if (!announcements || announcements.length === 0) {
            container.innerHTML = `<div class="text-muted small">Henüz bir duyuru bulunmuyor.</div>`;
            return;
        }

        container.innerHTML = announcements.map(a => {
            const date = new Date(a.createdAt || a.CreatedAt).toLocaleDateString();
            const teacherName = a.teacherName || a.TeacherName || 'Öğretmen';
            return `
                <div class="notification-item p-3 border rounded bg-white shadow-sm hover-elevate transition-all">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0 fw-bold text-primary"><i class="bi bi-info-circle me-1"></i> ${a.title || a.Title}</h6>
                        <small class="text-muted" style="font-size: 0.7rem;">${date}</small>
                    </div>
                    <p class="mb-2 text-muted small">${a.message || a.Message}</p>
                    <div class="text-end">
                        <span class="badge bg-light text-dark"><i class="bi bi-person me-1"></i>${teacherName}</span>
                    </div>
                </div>
            `;
        }).join('');
    };

    const renderStudentHomeworks = (homeworks) => {
        const container = document.getElementById('student-homeworks-container');
        if (!container) return;
        
        if (!homeworks || homeworks.length === 0) {
            container.innerHTML = `<div class="text-muted small">Şu an aktif bir ödeviniz bulunmuyor.</div>`;
            return;
        }

        container.innerHTML = homeworks.map(h => {
            const dueDate = new Date(h.dueDate || h.DueDate);
            const now = new Date();
            const dateStr = dueDate.toLocaleDateString();
            const teacherName = h.teacherName || h.TeacherName || 'Öğretmen';
            
            const isCompleted = localStorage.getItem('hw_completed_student_mock_' + (h.id || h.Id)) === 'true';

            let statusClass = "border-start border-4 border-warning";
            let badgeHtml = `<span class="badge bg-warning text-dark px-2 py-1" style="font-size: 0.65rem;">Son Gün: ${dateStr}</span>`;
            
            if (isCompleted) {
                statusClass = "border-start border-4 border-success bg-success-soft";
                badgeHtml = `<span class="badge bg-success px-2 py-1" style="font-size: 0.65rem;"><i class="bi bi-check-circle me-1"></i>Yapıldı</span>`;
            } else if (dueDate < now) {
                statusClass = "border-start border-4 border-danger";
                badgeHtml = `<span class="badge bg-danger px-2 py-1" style="font-size: 0.65rem;">Gecikmiş (${dateStr})</span>`;
            }

            return `
                <div class="notification-item p-3 rounded bg-white shadow-sm hover-elevate mb-2 ${statusClass}">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0 fw-bold text-dark">${h.subject || h.Subject} - ${h.topic || h.Topic}</h6>
                        ${badgeHtml}
                    </div>
                    <p class="mb-2 text-muted small">${h.description || h.Description}</p>
                    <div class="text-end">
                        <span class="badge bg-light text-dark"><i class="bi bi-person me-1"></i>${teacherName}</span>
                    </div>
                </div>
            `;
        }).join('');
    };

    const renderDailyGoal = (todayData, historyData) => {
        const schedules = todayData?.schedules || todayData?.Schedules || [];
        const totalTarget = schedules.length > 0 ? schedules.length : 10; // Varsayılan 10 hedef

        const history = historyData || [];
        const todayStr = new Date().toLocaleDateString('tr-TR');
        const completedToday = history.filter(h => {
            const dateVal = h.startTime || h.StartTime || h.completedAt || h.CompletedAt;
            if (!dateVal) return false;
            const d = new Date(dateVal);
            return d.toLocaleDateString('tr-TR') === todayStr;
        }).length;

        const percent = totalTarget > 0 ? Math.min((completedToday / totalTarget) * 100, 100) : 0;
        
        const pb = document.getElementById('daily-goal-bar');
        if (pb) pb.style.width = percent + '%';
        
        const pt = document.getElementById('daily-goal-text');
        if (pt) pt.textContent = `${completedToday}/${totalTarget}`;
        
        const gm = document.getElementById('daily-goal-message');
        if (gm) {
            if (completedToday >= totalTarget && totalTarget > 0) {
                gm.textContent = "Harika! Bugünkü hedefini tamamladın!";
                if (pb) pb.style.backgroundColor = "#28a745"; // Success color
            } else {
                const left = totalTarget - completedToday;
                gm.textContent = `Bugün ${left} ders daha tamamla!`;
            }
        }
    };

    const loadDailyCheckIn = () => safeLoad('Check-in', async () => {
        await fetch('/Gamification/CheckIn', { method: 'POST' });
    });

    const loadLeaderboard = () => safeLoad('Leaderboard', async () => {
        const data = await fetchJson('/LeaderboardProxy/GetGeneralLeaderboard?limit=10');
        renderLeaderboard(data);
    });

    const loadXpSummary = () => safeLoad('XP', async () => {
        const data = await fetchJson('/LeaderboardProxy/GetXpSummary');
        renderXp(data);
    });

    const loadStreak = () => safeLoad('Streak', async () => {
        const data = await fetchJson('/Gamification/StreakStatus');
        renderStreak(data);
    }, () => {
        setText('home-streak', '-');
    });

    const loadAchievements = () => safeLoad('Achievements', async () => {
        let data = null;
        try {
            data = await fetchJson('/Gamification/AllAchievements');
        } catch {
            // Bazı backend sürümlerinde all-achievements endpointi yok/hata verebilir.
        }

        let achievements = normalizeAchievements(data);
        if (!achievements.length) {
            const myData = await fetchJson('/Gamification/MyAchievements');
            achievements = normalizeAchievements(myData).map(a => ({
                ...a,
                isEarned: true,
                IsEarned: true
            }));
        }

        renderAchievements(achievements);
    }, () => setLoadError('home-achievements-container'));

    const loadAnnouncements = () => safeLoad('Announcements', async () => {
        const data = await fetchJson('/StudentPanelProxy/announcements');
        renderStudentAnnouncements(data);
    }, () => setLoadError('student-announcements-container'));

    const loadHomeworks = () => safeLoad('Homeworks', async () => {
        const data = await fetchJson('/StudentPanelProxy/homeworks');
        renderStudentHomeworks(data);
    }, () => setLoadError('student-homeworks-container'));

    const loadDailyGoal = () => safeLoad('Daily goal', async () => {
        const [todayData, historyData] = await Promise.all([
            fetchJson('/Pomodoro/TodaySchedule').catch(() => ({})),
            fetchJson('/Pomodoro/History?limit=100').catch(() => [])
        ]);
        renderDailyGoal(todayData, historyData);
    });

    (async () => {
        try {
            setStatus('Yükleniyor...', 'bg-light text-dark');

            await loadDailyCheckIn();
            await Promise.all([
                loadLeaderboard(),
                loadXpSummary(),
                loadStreak(),
                loadAchievements(),
                loadAnnouncements(),
                loadHomeworks(),
                loadDailyGoal()
            ]);
            
            setStatus('Hazır', 'bg-success');
        } catch (err) {
            console.error('Genel dashboard hatası', err);
            setStatus('Hata', 'bg-danger');
        }
    })();
})();
</script>
}
