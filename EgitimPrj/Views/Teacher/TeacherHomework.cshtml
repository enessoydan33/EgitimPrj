@{
    ViewData["Title"] = "Ödev Gönder";
}

<div class="teacher-hw-container fade-in-up mt-5">

    <!-- ===== HEADER ===== -->
    <div class="modern-page-header header-hw">
        <div class="modern-header-content">
            <div class="modern-header-icon">
                <i class="bi bi-clipboard2-check-fill"></i>
            </div>
            <div class="modern-header-text">
                <h1>Ödev Gönder</h1>
                <p>Sınıflarınıza veya tekil öğrencilere ödev ve ders görevleri gönderin.</p>
            </div>
        </div>
        <div class="modern-header-actions d-flex flex-wrap gap-2 justify-content-end">
            <a asp-action="HomeworkDocumentationPdf" asp-controller="Teacher" target="_blank" rel="noopener"
               class="btn btn-light text-danger fw-bold shadow-sm border">
                <i class="bi bi-file-earmark-pdf me-1"></i>Ödev kılavuzu (PDF)
            </a>
            <a asp-action="TeacherPanel" class="btn btn-light text-primary fw-bold shadow-sm">
                <i class="bi bi-arrow-left me-1"></i>Panele Dön
            </a>
        </div>
        <div class="modern-header-decoration"></div>
    </div>

    <div class="row g-4">
        <!-- SOL: Ödev Formu -->
        <div class="col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="icon-box icon-box-hw">
                        <i class="bi bi-clipboard2-check"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">Ödev / Ders Gönder</h5>
                        <p class="text-muted small mb-0">Sınıf veya tekil öğrenciye ödev gönderin</p>
                    </div>
                </div>

                <form id="homework-form">
                    <!-- Hedef -->
                    <div class="mb-3">
                        <label class="form-label-modern">Gönderim Hedefi</label>
                        <div class="d-flex gap-2">
                            <button type="button" class="target-btn active flex-fill" data-target="class">
                                <i class="bi bi-people me-1"></i>Sınıf Geneli
                            </button>
                            <button type="button" class="target-btn flex-fill" data-target="individual">
                                <i class="bi bi-person me-1"></i>Tekil Öğrenci
                            </button>
                        </div>
                    </div>

                    <!-- Sınıf seçimi -->
                    <div class="mb-3" id="hw-class-row">
                        <label class="form-label-modern">Sınıf</label>
                        <select class="form-select form-select-modern" id="hw-class">
                            <option value="10A">10-A Sınıfı</option>
                            <option value="10B">10-B Sınıfı</option>
                            <option value="11A">11-A Sınıfı</option>
                            <option value="11B">11-B Sınıfı</option>
                            <option value="12A">12-A Sınıfı</option>
                        </select>
                    </div>

                    <!-- Tekil öğrenci seçimi -->
                    <div class="mb-3 d-none" id="hw-student-row">
                        <label class="form-label-modern">Öğrenci</label>
                        <select class="form-select form-select-modern" id="hw-student">
                            <option value="">Öğrenci seçin...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-modern">Ders</label>
                        <select class="form-select form-select-modern" id="hw-subject">
                            <option value="matematik" data-color="#6366f1">Matematik</option>
                            <option value="fizik"     data-color="#3b82f6">Fizik</option>
                            <option value="kimya"     data-color="#10b981">Kimya</option>
                            <option value="biyoloji"  data-color="#22c55e">Biyoloji</option>
                            <option value="turkce"    data-color="#f59e0b">Türkçe</option>
                            <option value="tarih"     data-color="#ef4444">Tarih</option>
                            <option value="cografya"  data-color="#8b5cf6">Coğrafya</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label-modern">Konu / Başlık</label>
                        <input type="text" class="form-control form-control-modern" id="hw-title"
                               placeholder="Örn: Türev Soruları s.45-50" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label-modern">Son Teslim Tarihi</label>
                        <input type="date" class="form-control form-control-modern" id="hw-due" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label-modern">Açıklama (İsteğe Bağlı)</label>
                        <textarea class="form-control form-control-modern" id="hw-desc"
                                  rows="2" placeholder="Ek notlar..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-gradient-hw w-100 fw-bold py-3">
                        <i class="bi bi-send-fill me-2"></i>Ödev Gönder
                    </button>
                    <div id="hw-feedback" class="mt-3 text-center fw-medium d-none"></div>
                </form>
            </div>
        </div>

        <!-- SAĞ: Gönderilen Ödevler -->
        <div class="col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box icon-box-hw">
                            <i class="bi bi-list-task"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">Gönderilen Ödevler</h5>
                            <p class="text-muted small mb-0">Tüm aktif görevler</p>
                        </div>
                    </div>
                    <span class="badge bg-primary rounded-pill px-3 py-2" id="sent-count">0 Kayıt</span>
                </div>

                <div class="table-responsive">
                    <table class="table sent-table" id="sent-table">
                        <thead>
                            <tr>
                                <th>Kontrol</th>
                                <th>Hedef</th>
                                <th>Ders</th>
                                <th>Konu / Başlık</th>
                                <th>Son Teslim</th>
                                <th>Açıklama</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="sent-table-body">
                        </tbody>
                    </table>
                </div>
                <div class="text-center py-5 text-muted" id="sent-empty">
                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                    <p>Henüz gönderilen bir ödev yok.</p>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ===== ÖDEV KONTROL MODALI ===== -->
<div class="modal-overlay" id="check-modal-overlay" onclick="closeCheckModal()">
    <div class="check-modal" onclick="event.stopPropagation()">
        <div class="check-modal-header">
            <div class="check-modal-header-text">
                <h5 class="fw-bold mb-1" id="check-modal-title">Ödev Kontrol</h5>
                <p class="text-muted small mb-0" id="check-modal-subtitle">Yapan öğrencileri işaretleyin</p>
            </div>
            <div class="check-modal-header-actions">
                <a asp-action="HomeworkDocumentationPdf" asp-controller="Teacher" target="_blank" rel="noopener"
                   class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Modül kullanım kılavuzu">
                    <i class="bi bi-file-earmark-pdf me-1"></i>Kılavuz PDF
                </a>
                <button type="button" class="check-modal-close" onclick="closeCheckModal()" aria-label="Kapat">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="check-modal-body" id="check-modal-body">
        </div>
        <div class="check-modal-footer">
            <button type="button" class="btn btn-outline-secondary fw-semibold px-3 py-2 rounded-pill" onclick="openHomeworkSnapshotPdf()">
                <i class="bi bi-file-earmark-pdf me-1"></i>Bu ödevin özeti (PDF)
            </button>
            <button type="button" class="btn btn-gradient-hw fw-bold px-4 py-2" onclick="saveCheckModal()">
                <i class="bi bi-check2-all me-1"></i>Kaydet
            </button>
        </div>
    </div>
</div>

@section Styles {
<style>
    .fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @@keyframes fadeInUp {
        from { opacity:0; transform:translateY(20px); }
        to   { opacity:1; transform:translateY(0); }
    }

    .header-hw { background:linear-gradient(135deg,#4f46e5 0%,#6366f1 100%); }

    .glass-card {
        background:#fff; border-radius:24px;
        border:1px solid rgba(226,232,240,.8);
        box-shadow:0 10px 30px rgba(0,0,0,.03);
        transition:transform .3s,box-shadow .3s;
    }
    .glass-card:hover { transform:translateY(-4px); box-shadow:0 20px 40px rgba(0,0,0,.06); }

    .icon-box-hw {
        width:44px; height:44px; background:#e0e7ff; color:#4f46e5;
        border-radius:12px; display:flex; align-items:center;
        justify-content:center; font-size:1.1rem; flex-shrink:0;
    }

    .form-label-modern {
        font-size:.8rem; font-weight:700; text-transform:uppercase;
        letter-spacing:.5px; color:#64748b; margin-bottom:.4rem; display:block;
    }
    .form-control-modern, .form-select-modern {
        border:2px solid #e2e8f0; border-radius:12px;
        padding:.7rem 1rem; font-size:.95rem; color:#1e293b;
        background:#f8fafc; transition:all .3s;
    }
    .form-control-modern:focus, .form-select-modern:focus {
        background:#fff; border-color:#6366f1;
        box-shadow:0 0 0 4px rgba(99,102,241,.1); outline:none;
    }

    .target-btn {
        border:2px solid #e2e8f0; border-radius:12px;
        background:#f8fafc; color:#64748b; padding:.6rem .75rem;
        font-size:.85rem; font-weight:600; cursor:pointer;
        transition:all .2s;
    }
    .target-btn.active {
        border-color:#6366f1; background:#e0e7ff; color:#4f46e5;
    }
    .target-btn:hover:not(.active) { border-color:#c7d2fe; background:#f0f4ff; }

    .btn-gradient-hw {
        background:linear-gradient(135deg,#4f46e5 0%,#6366f1 100%);
        border:none; color:#fff; border-radius:12px;
        font-size:.95rem; letter-spacing:.5px;
        transition:filter .3s,transform .2s;
    }
    .btn-gradient-hw:hover { filter:brightness(110%); transform:translateY(-2px); color:#fff; }

    /* ===== SENT TABLE ===== */
    .sent-table { border-collapse:separate; border-spacing:0 8px; width:100%; }
    .sent-table thead th {
        font-size:.8rem; font-weight:700; text-transform:uppercase;
        letter-spacing:.5px; color:#94a3b8; border:none; padding:.6rem .8rem;
        background:transparent;
    }
    .sent-table tbody tr {
        background:#f8fafc; transition:background .2s, transform .2s;
    }
    .sent-table tbody tr:hover { background:#f1f5f9; transform:translateX(3px); }
    .sent-table tbody td {
        padding:.85rem .8rem; border:none; vertical-align:middle;
        font-size:.92rem; color:#1e293b;
    }
    .sent-table tbody td:first-child {
        border-radius:12px 0 0 12px; border-left:4px solid #6366f1;
    }
    .sent-table tbody td:last-child { border-radius:0 12px 12px 0; }
    .subject-badge {
        display:inline-flex; align-items:center; gap:4px;
        border-radius:20px; padding:3px 12px; font-size:.8rem; font-weight:700;
        background:#ede9fe; color:#7c3aed;
    }
    .btn-delete-row {
        width:30px; height:30px; border-radius:50%; border:none;
        background:rgba(239,68,68,.08); color:#ef4444;
        display:inline-flex; align-items:center; justify-content:center;
        cursor:pointer; transition:all .2s;
    }
    .btn-delete-row:hover { background:#ef4444; color:#fff; }

    /* Kontrol butonu */
    .btn-check-hw {
        border:2px solid #e2e8f0; border-radius:10px;
        background:#f8fafc; color:#64748b;
        padding:.35rem .7rem; font-size:.8rem; font-weight:700;
        cursor:pointer; transition:all .2s; white-space:nowrap;
    }
    .btn-check-hw:hover { border-color:#6366f1; background:#e0e7ff; color:#4f46e5; }
    .btn-check-hw .check-count {
        display:inline-flex; align-items:center; justify-content:center;
        background:#6366f1; color:#fff; border-radius:50%;
        width:20px; height:20px; font-size:.7rem; margin-left:4px;
    }

    /* ===== MODAL ===== */
    .modal-overlay {
        position:fixed; inset:0; background:rgba(15,23,42,.5);
        z-index:9999; display:none; align-items:center; justify-content:center;
        backdrop-filter:blur(4px);
    }
    .modal-overlay.active { display:flex; animation:fadeIn .2s; }
    @@keyframes fadeIn { from{opacity:0} to{opacity:1} }

    .check-modal {
        background:#fff; border-radius:24px; width:100%; max-width:520px;
        max-height:80vh; display:flex; flex-direction:column;
        box-shadow:0 25px 60px rgba(0,0,0,.15);
        animation:slideUp .3s ease-out;
    }
    @@keyframes slideUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

    .check-modal-header {
        display:flex; align-items:flex-start; justify-content:space-between; gap:.75rem;
        padding:1.5rem 1.5rem 1rem; border-bottom:1px solid #f1f5f9;
    }
    .check-modal-header-text { flex:1; min-width:0; }
    .check-modal-header-actions {
        display:flex; align-items:center; gap:.5rem; flex-shrink:0;
    }
    .check-modal-close {
        width:36px; height:36px; border-radius:50%; border:none;
        background:#f1f5f9; color:#64748b; cursor:pointer;
        display:flex; align-items:center; justify-content:center;
        transition:all .2s;
    }
    .check-modal-close:hover { background:#e2e8f0; color:#1e293b; }

    .check-modal-body {
        padding:1rem 1.5rem; overflow-y:auto; flex:1;
    }
    .check-student-row {
        display:flex; align-items:center; gap:.75rem;
        padding:.7rem .75rem; border-radius:12px;
        transition:background .15s; cursor:pointer;
    }
    .check-student-row:hover { background:#f8fafc; }
    .check-student-row input[type=checkbox] {
        width:20px; height:20px; accent-color:#6366f1;
        cursor:pointer; flex-shrink:0;
    }
    .check-student-name {
        font-weight:600; color:#1e293b; font-size:.95rem; flex:1;
    }
    .check-student-cls {
        font-size:.78rem; color:#94a3b8; font-weight:600;
    }

    .check-modal-footer {
        padding:1rem 1.5rem; border-top:1px solid #f1f5f9;
        display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:.75rem;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .spin { animation: spin 1s linear infinite; display:inline-block; }
</style>
}

@section Scripts {
<script>
window.__teacherHomeworkSnapshotPdfUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("HomeworkSnapshotPdf", "Teacher")));
</script>
<script src="~/js/teacher-homework.js" asp-append-version="true"></script>
}
