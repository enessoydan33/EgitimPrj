@{
    ViewData["Title"] = "Öğretmen Paneli";
}

<div class="teacher-panel-container fade-in-up mt-5">

    <!-- ===== HEADER ===== -->
    <div class="modern-page-header header-teacher">
        <div class="modern-header-content">
            <div class="modern-header-icon">
                <i class="bi bi-person-workspace"></i>
            </div>
            <div class="modern-header-text">
                <h1>Öğretmen Paneli</h1>
                <p>Öğrencilerinizi takip edin, ödev/duyuru gönderin ve performansları analiz edin.</p>
            </div>
        </div>
        <div class="modern-header-decoration"></div>
    </div>

    <!-- ===== HIZLI İSTATİSTİKLER ===== -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card-teacher">
                <div class="stat-icon bg-primary-soft"><i class="bi bi-people-fill text-primary"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="stat-students">8</div>
                    <div class="stat-label">Toplam Öğrenci</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card-teacher">
                <div class="stat-icon bg-success-soft"><i class="bi bi-clipboard2-check-fill text-success"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="stat-homeworks">0</div>
                    <div class="stat-label">Aktif Görev</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card-teacher">
                <div class="stat-icon bg-warning-soft"><i class="bi bi-bar-chart-fill text-warning"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="stat-avg-tyt">-</div>
                    <div class="stat-label">Ort. TYT Net</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card-teacher">
                <div class="stat-icon bg-danger-soft"><i class="bi bi-graph-up text-danger"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="stat-avg-ayt">-</div>
                    <div class="stat-label">Ort. AYT Net</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== HIZLI ERİŞİM KARTLARI ===== -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <a asp-action="TeacherHomework" class="text-decoration-none">
                <div class="nav-card nav-card-hw">
                    <div class="nav-card-icon">
                        <i class="bi bi-clipboard2-check-fill"></i>
                    </div>
                    <h5 class="nav-card-title">Ödev Gönder</h5>
                    <p class="nav-card-desc">Sınıflarınıza veya tekil öğrencilere ödev ve ders görevleri gönderin.</p>
                    <span class="btn btn-gradient-primary w-100 fw-bold">
                        <i class="bi bi-send-fill me-1"></i>Ödev Sayfası
                    </span>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="TeacherAnnouncement" class="text-decoration-none">
                <div class="nav-card nav-card-info">
                    <div class="nav-card-icon">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <h5 class="nav-card-title">Duyuru Gönder</h5>
                    <p class="nav-card-desc">Sınıflarınıza veya tekil öğrencilere duyuru ve bilgi gönderin.</p>
                    <span class="btn btn-gradient-info w-100 fw-bold">
                        <i class="bi bi-megaphone me-1"></i>Duyuru Sayfası
                    </span>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="TeacherExam" class="text-decoration-none">
                <div class="nav-card nav-card-exam">
                    <div class="nav-card-icon">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h5 class="nav-card-title">Deneme Ekle</h5>
                    <p class="nav-card-desc">Öğrencilerinizin TYT/AYT deneme sonuçlarını girin ve takip edin.</p>
                    <span class="btn btn-gradient-exam w-100 fw-bold">
                        <i class="bi bi-journal-plus me-1"></i>Deneme Sayfası
                    </span>
                </div>
            </a>
        </div>
    </div>

    <!-- ===== SINIF OLUŞTUR + ÖĞRENCİ EKLE ===== -->
    <div class="row g-4 mt-2">
        <div class="col-12 col-xl-5">
            <div class="glass-card-manage p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box-manage">
                        <i class="bi bi-door-open-fill"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">Yeni Sınıf Oluştur</h5>
                        <p class="text-muted small mb-0">
                            Önce sınıflarınızı oluşturun, ardından öğrenci atayın.
                        </p>
                    </div>
                </div>

                <form id="create-classroom-form" class="row g-3">
                    <div class="col-12">
                        <label class="form-label-manage">Sınıf Adı</label>
                        <input type="text"
                               class="form-control form-control-modern"
                               id="create-classroom-name"
                               placeholder="Örn: 10-A"
                               required />
                    </div>
                    <div class="col-12">
                        <label class="form-label-manage">Açıklama (İsteğe Bağlı)</label>
                        <input type="text"
                               class="form-control form-control-modern"
                               id="create-classroom-description"
                               placeholder="Örn: Sayısal sınıf" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-gradient-primary w-100 fw-bold py-2">
                            <i class="bi bi-plus-circle me-1"></i>Sınıf Oluştur
                        </button>
                    </div>
                    <div class="col-12">
                        <div id="create-classroom-feedback" class="mt-2 small fw-semibold d-none"></div>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="glass-card-manage p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box-manage icon-box-student">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">Sınıfa Öğrenci Ekle</h5>
                        <p class="text-muted small mb-0">
                            Sınıf seçin ve öğrenci ID'si girerek öğrenci atayın.
                        </p>
                    </div>
                </div>

                <form id="add-student-to-class-form" class="row g-3 align-items-end">
                    <div class="col-12 col-md-5">
                        <label class="form-label-manage">Seçili Sınıf</label>
                        <div class="form-control-modern" style="background:#f8fafc;" id="selected-classroom-label">
                            Sınıf seçin...
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label-manage">Öğrenci ID</label>
                        <input type="number"
                               id="manage-class-student-id"
                               class="form-control form-control-modern"
                               placeholder="Öğrenci ID girin"
                               min="1"
                               required />
                    </div>
                    <div class="col-12 col-md-3">
                        <button type="submit" class="btn btn-gradient-primary w-100 fw-bold py-2 mt-2 mt-md-0">
                            <i class="bi bi-person-plus me-1"></i>Ekle
                        </button>
                    </div>
                    <div class="col-12">
                        <div id="manage-class-feedback" class="mt-2 small fw-semibold d-none"></div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ===== SEÇİLİ SINIFIN ÖĞRENCİLERİ ===== -->
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="glass-card-manage p-4">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box-manage icon-box-list">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">Sınıf Öğrenci Listesi</h5>
                            <p class="text-muted small mb-0" id="student-list-subtitle">
                                Aşağıdaki kutudan sınıf seçerek öğrencileri görüntüleyin.
                            </p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <select class="form-select form-select-modern" id="manage-class-classroom" style="min-width: 180px;">
                            <option value="">Sınıf seçin...</option>
                        </select>
                        <span class="badge bg-primary-soft text-primary px-3 py-2 fs-6" id="student-count-badge" style="display:none;">
                            <i class="bi bi-people me-1"></i><span id="student-count-text">0</span> Öğrenci
                        </span>
                    </div>
                </div>

                <div id="student-list-area">
                    <div class="text-center text-muted py-4" id="student-list-placeholder">
                        <i class="bi bi-arrow-up-circle" style="font-size:2rem;opacity:.4;"></i>
                        <p class="mt-2 mb-0">Yukarıdan bir sınıf seçin</p>
                    </div>
                    <div class="table-responsive d-none" id="student-table-container">
                        <table class="table table-student-list align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width:60px;">#</th>
                                    <th>Öğrenci Adı</th>
                                    <th class="text-center" style="width:120px;">Deneme Sayısı</th>
                                    <th class="text-center" style="width:100px;">Ort. TYT</th>
                                    <th class="text-center" style="width:100px;">Ort. AYT</th>
                                    <th class="text-center" style="width:120px;">Hedef</th>
                                    <th class="text-center" style="width:100px;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody id="student-table-body">
                            </tbody>
                        </table>
                    </div>
                    <div class="text-center text-muted py-4 d-none" id="student-list-empty">
                        <i class="bi bi-inbox" style="font-size:2rem;opacity:.4;"></i>
                        <p class="mt-2 mb-0">Bu sınıfta henüz öğrenci bulunmuyor.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div><!-- /teacher-panel-container -->

@section Styles {
<style>
    /* ===== ANIMASYON ===== */
    .fade-in-up { animation: fadeInUp 0.6s ease-out; }
    @@keyframes fadeInUp {
        from { opacity:0; transform:translateY(20px); }
        to   { opacity:1; transform:translateY(0); }
    }

    /* ===== STAT CARDS ===== */
    .stat-card-teacher {
        background:#fff; border-radius:20px;
        border:1px solid rgba(226,232,240,.8);
        padding:1.1rem 1.25rem;
        display:flex; align-items:center; gap:.9rem;
        box-shadow:0 4px 15px rgba(0,0,0,.03);
        transition:transform .3s,box-shadow .3s;
    }
    .stat-card-teacher:hover { transform:translateY(-4px); box-shadow:0 12px 30px rgba(0,0,0,.07); }
    .stat-icon {
        width:50px; height:50px; border-radius:14px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.35rem; flex-shrink:0;
    }
    .bg-primary-soft{background:#e0e7ff} .bg-success-soft{background:#dcfce7}
    .bg-warning-soft{background:#fef9c3} .bg-danger-soft{background:#fee2e2}
    .stat-value { font-size:1.6rem; font-weight:800; color:#1e293b; line-height:1; }
    .stat-label  { font-size:.75rem; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-top:4px; }

    /* ===== NAV CARDS ===== */
    .nav-card {
        background:#fff; border-radius:28px;
        border:1px solid rgba(226,232,240,.8);
        box-shadow:0 10px 30px rgba(0,0,0,.03);
        padding:2.8rem 2rem; text-align:center;
        transition:transform .3s,box-shadow .3s;
        height:100%;
    }
    .nav-card:hover { transform:translateY(-6px); box-shadow:0 20px 40px rgba(0,0,0,.08); }
    .nav-card-icon {
        width:84px; height:84px; border-radius:22px;
        display:inline-flex; align-items:center; justify-content:center;
        font-size:2.2rem; margin-bottom:1.25rem;
    }
    .nav-card-hw .nav-card-icon { background:#e0e7ff; color:#4f46e5; }
    .nav-card-info .nav-card-icon { background:#e0f2fe; color:#0284c7; }
    .nav-card-exam .nav-card-icon { background:#fff7ed; color:#ea580c; }
    .nav-card-title { font-weight:800; color:#1e293b; font-size:1.35rem; margin-bottom:.6rem; }
    .nav-card-desc { font-size:1rem; color:#64748b; margin-bottom:1.5rem; line-height:1.6; }

    /* ===== HEADER ===== */
    .header-teacher { background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%); }

    /* ===== GRADIENT BUTTONS ===== */
    .btn-gradient-primary {
        background:linear-gradient(135deg,#4f46e5 0%,#6366f1 100%);
        border:none; color:#fff; border-radius:12px;
        font-size:.95rem; letter-spacing:.5px;
        transition:filter .3s,transform .2s;
    }
    .btn-gradient-primary:hover { filter:brightness(110%); transform:translateY(-2px); color:#fff; }

    .btn-gradient-info {
        background:linear-gradient(135deg,#0ea5e9 0%,#38bdf8 100%);
        border:none; color:#fff; border-radius:12px;
        font-size:.95rem; letter-spacing:.5px;
        transition:filter .3s,transform .2s;
    }
    .btn-gradient-info:hover { filter:brightness(110%); transform:translateY(-2px); color:#fff; }

    .btn-gradient-exam {
        background:linear-gradient(135deg,#ea580c 0%,#f97316 100%);
        border:none; color:#fff; border-radius:12px;
        font-size:.95rem; letter-spacing:.5px;
        transition:filter .3s,transform .2s;
    }
    .btn-gradient-exam:hover { filter:brightness(110%); transform:translateY(-2px); color:#fff; }

    /* ===== SINIF / ÖĞRENCİ YÖNETİM KARTI ===== */
    .glass-card-manage {
        background:#fff; border-radius:24px;
        border:1px solid rgba(226,232,240,.8);
        box-shadow:0 10px 30px rgba(0,0,0,.03);
        transition:transform .3s,box-shadow .3s;
    }
    .glass-card-manage:hover {
        transform:translateY(-4px);
        box-shadow:0 20px 40px rgba(0,0,0,.06);
    }
    .icon-box-manage {
        width:44px; height:44px; background:#e0f2fe; color:#0284c7;
        border-radius:12px; display:flex; align-items:center;
        justify-content:center; font-size:1.1rem; flex-shrink:0;
    }
    .icon-box-student { background:#dcfce7; color:#16a34a; }
    .icon-box-list { background:#fef9c3; color:#ca8a04; }
    .form-label-manage {
        font-size:.8rem; font-weight:700; text-transform:uppercase;
        letter-spacing:.5px; color:#64748b; margin-bottom:.3rem; display:block;
    }
    .form-control-modern, .form-select-modern {
        border:2px solid #e2e8f0; border-radius:12px;
        padding:.6rem .9rem; font-size:.95rem; color:#1e293b;
        background:#f8fafc; transition:all .3s;
    }
    .form-control-modern:focus, .form-select-modern:focus {
        background:#fff; border-color:#4f46e5;
        box-shadow:0 0 0 4px rgba(79,70,229,.1); outline:none;
    }
    #manage-class-feedback.text-success,
    #create-classroom-feedback.text-success {
        color:#16a34a !important;
    }
    #manage-class-feedback.text-danger,
    #create-classroom-feedback.text-danger {
        color:#dc2626 !important;
    }

    /* ===== ÖĞRENCİ LİSTE TABLOSU ===== */
    .table-student-list {
        border-collapse: separate;
        border-spacing: 0;
    }
    .table-student-list thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        color: #64748b;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: .75rem 1rem;
    }
    .table-student-list tbody tr {
        transition: background .2s;
    }
    .table-student-list tbody tr:hover {
        background: #f1f5f9;
    }
    .table-student-list tbody td {
        padding: .85rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        font-size: .92rem;
        color: #334155;
    }
    .student-avatar-sm {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: .85rem;
        margin-right: .6rem;
        flex-shrink: 0;
    }
    .btn-remove-student {
        background: #fee2e2;
        color: #dc2626;
        border: none;
        border-radius: 10px;
        padding: .4rem .7rem;
        font-size: .8rem;
        font-weight: 600;
        transition: all .2s;
        cursor: pointer;
    }
    .btn-remove-student:hover {
        background: #dc2626;
        color: #fff;
        transform: scale(1.05);
    }
</style>
}

@section Scripts {
<script>
async function tpApiGet(url) {
    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
}

async function tpApiPost(url, body) {
    const res = await fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        },
        body: JSON.stringify(body ?? {})
    });
    if (!res.ok) {
        const text = await res.text();
        throw new Error(`HTTP ${res.status}: ${text}`);
    }
    const ct = res.headers.get('Content-Type') || '';
    if (ct.includes('application/json')) {
        return await res.json();
    }
    return await res.text();
}

async function tpApiDelete(url) {
    const res = await fetch(url, {
        method: 'DELETE',
        headers: { 'Accept': 'application/json' }
    });
    if (!res.ok) {
        const text = await res.text();
        throw new Error(`HTTP ${res.status}: ${text}`);
    }
    const ct = res.headers.get('Content-Type') || '';
    if (ct.includes('application/json')) {
        return await res.json();
    }
    return await res.text();
}

let manageClassrooms = [];

// ===== ÜST İSTATİSTİKLERİ YÜKLE =====
async function loadDashboardStats() {
    // Toplam öğrenci: sınıflardaki studentCount alanlarının toplamı
    try {
        const classrooms = await tpApiGet('/TeacherPanelProxy/Classrooms');
        let totalStudents = 0;
        (Array.isArray(classrooms) ? classrooms : []).forEach(c => {
            if (typeof c.studentCount === 'number') {
                totalStudents += c.studentCount;
            } else if (Array.isArray(c.students)) {
                totalStudents += c.students.length;
            }
        });
        const elStudents = document.getElementById('stat-students');
        if (elStudents) elStudents.textContent = totalStudents.toString();
    } catch (err) {
        console.error('Toplam öğrenci yüklenemedi', err);
    }

    // Aktif görev: öğretmenin tüm ödev sayısı
    try {
        const homeworks = await tpApiGet('/TeacherPanelProxy/Homeworks');
        const count = Array.isArray(homeworks) ? homeworks.length : 0;
        const elHw = document.getElementById('stat-homeworks');
        if (elHw) elHw.textContent = count.toString();
    } catch (err) {
        console.error('Ödevler yüklenemedi', err);
    }

    // Ortalama TYT ve AYT net hesapla
    try {
        const classrooms = await tpApiGet('/TeacherPanelProxy/Classrooms');
        let sumAvgTyt = 0;
        let tytCount = 0;
        let sumAvgAyt = 0;
        let aytCount = 0;

        for (const c of (Array.isArray(classrooms) ? classrooms : [])) {
            if (!c || typeof c.id !== 'number') continue;
            try {
                const performances = await tpApiGet(`/TeacherPanelProxy/ClassroomPerformances?classroomId=${encodeURIComponent(c.id)}`);
                const students = Array.isArray(performances) ? performances : [];

                // Fetch exam lists for all active students in parallel
                const examPromises = students.map(s => tpApiGet(`/TeacherPanelProxy/StudentTrialExams?classroomId=${c.id}&studentId=${s.studentId}`).catch(() => null));
                const examsResults = await Promise.all(examPromises);

                students.forEach((s, idx) => {
                    const result = examsResults[idx];
                    if (result && Array.isArray(result.trials)) {
                        const tytExams = result.trials.filter(t => t.examType === 'TYT' || t.examType === 'TYT+AYT');
                        if (tytExams.length > 0) {
                            const sum = tytExams.reduce((acc, t) => acc + (t.totalNet || 0), 0);
                            sumAvgTyt += (sum / tytExams.length);
                            tytCount++;
                        }
                        
                        const aytExams = result.trials.filter(t => t.examType === 'AYT' || t.examType === 'TYT+AYT');
                        if (aytExams.length > 0) {
                            const sum = aytExams.reduce((acc, t) => acc + (t.totalNet || 0), 0);
                            sumAvgAyt += (sum / aytExams.length);
                            aytCount++;
                        }
                    }
                });
            } catch (innerErr) {
                console.error('Performanslar yüklenemedi', innerErr);
            }
        }

        const elTyt = document.getElementById('stat-avg-tyt');
        if (elTyt) {
            const avgTyt = tytCount > 0 ? (sumAvgTyt / tytCount) : 0;
            elTyt.textContent = avgTyt.toFixed(1);
        }

        const elAyt = document.getElementById('stat-avg-ayt');
        if (elAyt) {
            const avgAyt = aytCount > 0 ? (sumAvgAyt / aytCount) : 0;
            elAyt.textContent = avgAyt.toFixed(1);
        }
    } catch (err) {
        console.error('İstatistikler hesaplanamadı', err);
    }
}

// ===== SINIF YÜKLEME =====
async function loadClassroomsForManage(keepSelectedId) {
    const select = document.getElementById('manage-class-classroom');
    if (!select) return;
    // Eğer keepSelectedId verilmediyse, şu anki seçimi koru
    const selectedId = keepSelectedId || select.value;
    try {
        const data = await tpApiGet('/TeacherPanelProxy/Classrooms');
        const classrooms = Array.isArray(data) ? data : [];
        manageClassrooms = classrooms;
        select.innerHTML = '<option value="">Sınıf seçin...</option>';
        classrooms.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.id;
            opt.textContent = `${c.name || 'Sınıf #' + c.id} (${c.studentCount || 0} öğrenci)`;
            select.appendChild(opt);
        });
        // Önceki seçimi geri yükle
        if (selectedId) {
            select.value = selectedId;
        }
    } catch (err) {
        console.error('Sınıflar yüklenemedi', err);
    }
}

// ===== SINIFTAKI ÖĞRENCİLERİ YÜKLE VE LİSTELE =====
async function loadClassroomStudents(classroomId) {
    const placeholder  = document.getElementById('student-list-placeholder');
    const tableContainer = document.getElementById('student-table-container');
    const emptyMsg     = document.getElementById('student-list-empty');
    const tableBody    = document.getElementById('student-table-body');
    const subtitle     = document.getElementById('student-list-subtitle');
    const countBadge   = document.getElementById('student-count-badge');
    const countText    = document.getElementById('student-count-text');

    if (!classroomId) {
        placeholder.classList.remove('d-none');
        tableContainer.classList.add('d-none');
        emptyMsg.classList.add('d-none');
        countBadge.style.display = 'none';
        subtitle.textContent = 'Yukarıdan sınıf seçerek öğrencileri görüntüleyin.';
        const selectedLabel = document.getElementById('selected-classroom-label');
        if (selectedLabel) selectedLabel.textContent = 'Sınıf seçin...';
        return;
    }

    placeholder.classList.add('d-none');
    tableContainer.classList.add('d-none');
    emptyMsg.classList.add('d-none');

    const selectedClassroom = manageClassrooms.find(c => c.id == classroomId);
    const className = selectedClassroom ? selectedClassroom.name : `Sınıf #${classroomId}`;
    subtitle.textContent = `${className} sınıfının öğrencileri yükleniyor...`;
    const selectedLabel = document.getElementById('selected-classroom-label');
    if (selectedLabel) selectedLabel.textContent = className;

    try {
        const performances = await tpApiGet(`/TeacherPanelProxy/ClassroomPerformances?classroomId=${encodeURIComponent(classroomId)}`);
        const students = Array.isArray(performances) ? performances : [];

        subtitle.textContent = `${className} sınıfındaki öğrenciler`;
        countBadge.style.display = '';
        countText.textContent = students.length;

        if (students.length === 0) {
            emptyMsg.classList.remove('d-none');
            return;
        }

        subtitle.textContent = `${className} sınıfındaki öğrenciler verileri yükleniyor...`;
        
        // Load exam data for each student to calculate TYT and AYT averages
        const examPromises = students.map(s => tpApiGet(`/TeacherPanelProxy/StudentTrialExams?classroomId=${classroomId}&studentId=${s.studentId}`).catch(() => null));
        const examsResults = await Promise.all(examPromises);
        
        tableBody.innerHTML = '';
        students.forEach((s, idx) => {
            const result = examsResults[idx];
            let avgTyt = 0;
            let avgAyt = 0;

            if (result && Array.isArray(result.trials)) {
                const tytExams = result.trials.filter(t => t.examType === 'TYT' || t.examType === 'TYT+AYT');
                if (tytExams.length > 0) {
                    const sum = tytExams.reduce((acc, t) => acc + (t.totalNet || 0), 0);
                    avgTyt = sum / tytExams.length;
                }
                
                const aytExams = result.trials.filter(t => t.examType === 'AYT' || t.examType === 'TYT+AYT');
                if (aytExams.length > 0) {
                    const sum = aytExams.reduce((acc, t) => acc + (t.totalNet || 0), 0);
                    avgAyt = sum / aytExams.length;
                }
            }

            const initials = getInitials(s.studentName || '');
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="text-muted fw-semibold">${idx + 1}</td>
                <td>
                    <div class="d-flex align-items-center">
                        <span class="student-avatar-sm">${initials}</span>
                        <div>
                            <div class="fw-semibold">${escapeHtml(s.studentName || 'Bilinmiyor')}</div>
                            <div class="text-muted" style="font-size:.78rem;">ID: ${s.studentId}</div>
                        </div>
                    </div>
                </td>
                <td class="text-center fw-semibold">${s.totalTrialExams ?? 0}</td>
                <td class="text-center fw-semibold text-warning">${avgTyt.toFixed(1)}</td>
                <td class="text-center fw-semibold text-danger">${avgAyt.toFixed(1)}</td>
                <td class="text-center">
                    <span class="badge ${s.targetExam === 'AYT' ? 'bg-warning-soft text-warning' : 'bg-primary-soft text-primary'} px-2 py-1" style="font-size:.78rem;">
                        ${escapeHtml(s.targetExam || 'TYT')}
                    </span>
                </td>
                <td class="text-center">
                    <button class="btn-remove-student" onclick="removeStudentFromClassroom(${classroomId}, ${s.studentId})" title="Sınıftan çıkar">
                        <i class="bi bi-person-dash me-1"></i>Çıkar
                    </button>
                </td>
            `;
            tableBody.appendChild(tr);
        });

        tableContainer.classList.remove('d-none');
        subtitle.textContent = `${className} sınıfındaki öğrenciler`;

        // İstatistikleri güncelle (Sadece genel tablo üzerinden yapıyoruz, en üstteki genel istatistikleri bozmamak için)
        // Eğer seçili sınıfın istatistiğini yukarıdaki panoya yansıtmak isterseniz aşağıyı güncelleyebilirsiniz:
        // document.getElementById('stat-students').textContent = students.length;
        // let sumTyt = 0, sumAyt = 0, tytCount = 0, aytCount = 0;
        // students.forEach(s => {
        //     if(s.averageTytNetScore > 0) { sumTyt += s.averageTytNetScore; tytCount++; }
        //     if(s.averageAytNetScore > 0) { sumAyt += s.averageAytNetScore; aytCount++; }
        // });
        // if(tytCount > 0) document.getElementById('stat-avg-tyt').textContent = (sumTyt/tytCount).toFixed(1);
        // if(aytCount > 0) document.getElementById('stat-avg-ayt').textContent = (sumAyt/aytCount).toFixed(1);

    } catch (err) {
        console.error('Öğrenciler yüklenemedi', err);
        subtitle.textContent = 'Öğrenci listesi yüklenemedi.';
        emptyMsg.classList.remove('d-none');
    }
}

// ===== ÖĞRENCİ SINIFTAN ÇIKAR =====
async function removeStudentFromClassroom(classroomId, studentId) {
    if (!confirm('Bu öğrenciyi sınıftan çıkarmak istediğinize emin misiniz?')) return;

    try {
        await tpApiDelete(`/TeacherPanelProxy/RemoveStudentFromClassroom?classroomId=${classroomId}&studentId=${studentId}`);
        await loadClassroomsForManage(classroomId.toString());
        await loadClassroomStudents(classroomId);
        showFeedback('manage-class-feedback', '✅ Öğrenci başarıyla sınıftan çıkarıldı.', 'success');
    } catch (err) {
        console.error('Öğrenci çıkarılamadı', err);
        showFeedback('manage-class-feedback', '❌ Öğrenci çıkarılamadı.', 'danger');
    }
}

function showFeedback(elementId, message, type) {
    const el = document.getElementById(elementId);
    if (!el) return;
    el.classList.remove('d-none', 'text-success', 'text-danger');
    el.textContent = message;
    el.classList.add(`text-${type}`);
    setTimeout(() => el.classList.add('d-none'), 3500);
}

function getInitials(name) {
    return name.split(' ').map(w => w.charAt(0).toUpperCase()).slice(0, 2).join('');
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// ===== SAYFA YÜKLEME =====
document.addEventListener('DOMContentLoaded', () => {
    loadDashboardStats();
    loadClassroomsForManage();

    // Sınıf Oluşturma
    const createForm = document.getElementById('create-classroom-form');
    if (createForm) {
        createForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('create-classroom-name').value.trim();
            const description = document.getElementById('create-classroom-description').value.trim();
            if (!name) return;

            showFeedback('create-classroom-feedback', 'Sınıf oluşturuluyor...', 'primary');

            try {
                await tpApiPost('/TeacherPanelProxy/CreateClassroom', {
                    name: name,
                    description: description || null
                });
                showFeedback('create-classroom-feedback', '✅ Sınıf başarıyla oluşturuldu.', 'success');
                createForm.reset();
                await loadClassroomsForManage();
            } catch (err) {
                console.error('Sınıf oluşturulamadı', err);
                showFeedback('create-classroom-feedback', '❌ Sınıf oluşturulamadı.', 'danger');
            }
        });
    }

    // Sınıf seçildiğinde öğrenci listesini yükle
    const classSelect = document.getElementById('manage-class-classroom');
    if (classSelect) {
        classSelect.addEventListener('change', () => {
            const classroomId = parseInt(classSelect.value);
            loadClassroomStudents(classroomId || null);
        });
    }

    // Öğrenci Ekleme
    const addForm = document.getElementById('add-student-to-class-form');
    if (addForm) {
        addForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const classroomId = parseInt(document.getElementById('manage-class-classroom').value);
            const studentId = parseInt(document.getElementById('manage-class-student-id').value);

            if (!classroomId || !studentId) {
                showFeedback('manage-class-feedback', '⚠️ Lütfen sınıf seçin ve öğrenci ID girin.', 'danger');
                return;
            }

            showFeedback('manage-class-feedback', 'Öğrenci ekleniyor...', 'primary');

            try {
                await tpApiPost(`/TeacherPanelProxy/AddStudentToClassroom?classroomId=${encodeURIComponent(classroomId)}&studentId=${encodeURIComponent(studentId)}`, {});
                showFeedback('manage-class-feedback', '✅ Öğrenci başarıyla sınıfa eklendi!', 'success');
                document.getElementById('manage-class-student-id').value = '';
                // Önce dropdown'ı güncelle (seçimi koruyarak), sonra listeyi yükle
                await loadClassroomsForManage(classroomId.toString());
                await loadClassroomStudents(classroomId);
            } catch (err) {
                console.error('Öğrenci eklenemedi', err);
                let errorMsg = '❌ Öğrenci eklenemedi.';
                const errText = err.message || '';
                if (errText.includes('400')) {
                    errorMsg = '❌ Öğrenci eklenemedi. ID geçersiz veya öğrenci zaten bir sınıfta olabilir.';
                } else if (errText.includes('401') || errText.includes('403')) {
                    errorMsg = '❌ Bu işlem için yetkiniz yok.';
                }
                showFeedback('manage-class-feedback', errorMsg, 'danger');
            }
        });
    }
});
</script>
}
