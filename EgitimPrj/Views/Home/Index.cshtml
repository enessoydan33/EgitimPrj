@{
    ViewData["Title"] = "CoMentor - Geleceğin Eğitim Platformu";
}

<!-- Hero Section -->
<!-- Hero Section -->
<section class="landing-hero d-flex align-items-center">
    <div class="container position-relative z-1">
        <div class="row align-items-center">
             
            <!-- Metin Alanı -->
            <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0">
                <span class="section-label">Geleceğin Eğitim Platformu</span>
                <h1 class="fw-bold display-4 mt-3 mb-4 lh-sm">Öğren, Geliş, <br><span class="text-gradient-primary">Başarıya Ulaş</span></h1>
                <p class="lead text-muted mb-5" style="max-width: 500px;">
                    Binlerce ders ve kaynakla kendi hızında öğrenmeye başla. Kariyerine güç katacak yetkinlikleri bugün edin.
                </p>
             
                
                <div class="mt-5">
                     <a href="#satinal" class="btn btn-primary btn-lg btn-pill btn-lg-custom shadow-lg">Hemen Başla</a>
                     <a href="#" class="btn btn-link link-dark text-decoration-none ms-3">Daha Fazla Bilgi <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>

            <!-- Görsel Alanı -->
            <div class="col-lg-6 text-center position-relative">
                <div class="glass-card-premium p-4 d-inline-block">
                    <img src="~/image/undraw_deep-work_muov.svg" alt="Eğitim Görseli" class="img-fluid rounded-4" style="max-height: 420px;">
                </div>
                
                <!-- Floating Badge 1 -->
                <div class="position-absolute top-0 end-0 mt-4 me-n4 bg-white p-3 rounded-4 shadow-lg d-none d-lg-block glass-card-premium" style="max-width: 200px;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-gradient-green rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                            <i class="bi bi-graph-up fs-4"></i>
                        </div>
                        <div class="text-start lh-1">
                            <div class="fw-bold text-dark mb-1">%35</div>
                            <small class="text-muted" style="font-size: 0.75rem;">Verimlilik Artışı</small>
                        </div>
                    </div>
                </div>

                <!-- Floating Badge 2 -->
                <div class="position-absolute bottom-0 start-0 mb-5 ms-n4 bg-white p-3 rounded-4 shadow-lg d-none d-lg-block glass-card-premium">
                     <div class="d-flex align-items-center gap-3">
                        <div class="bg-gradient-purple rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                            <i class="bi bi-trophy fs-4"></i>
                        </div>
                        <div class="text-start lh-1">
                            <div class="fw-bold text-dark mb-1">Topluluk</div>
                            <small class="text-muted" style="font-size: 0.75rem;">Lider Tablosu</small>
                        </div>
                    </div>
                </div>
            </div>
   
        </div>
    </div>
</section>

<!-- Özellikler -->
<!-- Özellikler -->
<section class="py-5 position-relative">
    <div class="container">
        <div class="row mb-5 text-center">
            <div class="col-lg-8 mx-auto">
                <span class="section-label">Özellikler</span>
                <h2 class="fw-bold display-6 mb-3">Neden Bizi Tercih Etmelisin?</h2>
                <p class="lead text-muted">Sadece çalışmak değil, doğru şekilde çalışmak için ihtiyacın olan her şey burada.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 glass-card-premium p-4">
                    <div class="card-body p-0">
                        <div class="feature-icon-box bg-gradient-blue text-white shadow-sm">
                            <i class="bi bi-robot" aria-hidden="true"></i>
                        </div>
                        <h4 class="card-title fw-bold mb-3">Yapay Zeka Desteği</h4>
                        <p class="card-text text-muted">Kişisel hedeflerine göre özel programlar oluştur. Yapay zekâ sayesinde hangi konulara ağırlık vermen gerektiğini öğren.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                 <div class="card h-100 border-0 glass-card-premium p-4">
                    <div class="card-body p-0">
                         <div class="feature-icon-box bg-gradient-green text-white shadow-sm">
                            <i class="bi bi-activity" aria-hidden="true"></i>
                        </div>
                        <h4 class="card-title fw-bold mb-3">Takip ve Analiz</h4>
                        <p class="card-text text-muted">Deneme sınavlarını kaydet, ilerlemeni düzenli takip et. Çalışma sürelerini analiz ederek güçlü yönlerini gör.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                 <div class="card h-100 border-0 glass-card-premium p-4">
                    <div class="card-body p-0">
                         <div class="feature-icon-box bg-gradient-purple text-white shadow-sm">
                            <i class="bi bi-people" aria-hidden="true"></i>
                        </div>
                        <h4 class="card-title fw-bold mb-3">Çalışma Grupları</h4>
                        <p class="card-text text-muted">Arkadaşlarınla grup oluştur. Birlikte soru çöz, motivasyonunu yüksek tut ve öğrenme yolculuğunu paylaş.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA: modern tasarım -->
<section class="py-5 my-5">
    <div class="container">
        <div class="glass-card-premium bg-gradient-blue p-5 rounded-5 text-center position-relative overflow-hidden">
             <div class="position-relative z-1">
                <h3 class="fw-bold display-5 mb-3">Hazır mısın?</h3>
                <p class="lead mb-4 opacity-75">Planını seç ve binlerce öğrenci arasına katıl.</p>
                <a href="#satinal" class="btn btn-primary btn-lg px-5 py-3 btn-pill shadow-lg">Planları Gör</a>
             </div>
             <!-- Decorative circles for CTA -->
             <div class="position-absolute top-0 start-0 translate-middle rounded-circle bg-white opacity-25" style="width: 300px; height: 300px; filter: blur(50px);"></div>
             <div class="position-absolute bottom-0 end-0 translate-middle rounded-circle bg-white opacity-25" style="width: 200px; height: 200px; filter: blur(40px);"></div>
        </div>
    </div>
</section>

<!-- Satın Alma -->
<section id="satinal" class="py-5 mb-5">
    <div class="container">
        <div class="row mb-5 text-center">
            <div class="col-lg-8 mx-auto">
                <span class="section-label">Üyelik Planları</span>
                <h2 class="fw-bold display-6 mb-3">Sana Uygun Planı Seç</h2>
                <p class="text-muted">İhtiyacına uygun paketi seçerek hemen başlayabilirsin.</p>
            </div>
        </div>

        <div class="row g-4 justify-content-center align-items-center">
            <!-- Standart Plan -->
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm glass-card-premium pricing-card">
                    <div class="card-body p-4 p-lg-5">
                        <h5 class="fw-bold text-muted mb-4">Standart</h5>
                        <div class="display-6 fw-bold mb-2 text-dark">₺99<span class="fs-6 fw-normal text-muted">/ay</span></div>
                        <p class="text-muted small mb-4">Başlangıç seviyesi için ideal.</p>
                        
                        <ul class="list-unstyled mb-4">
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> Temel kurslara erişim</li>
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> İlerleme takibi</li>
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> Topluluk desteği</li>
                        </ul>
                        <a href="#" class="btn btn-outline-primary w-100 btn-pill py-2 fw-semibold">Planı Seç</a>
                    </div>
                </div>
            </div>
            
            <!-- Profesyonel Plan -->
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow glass-card-premium pricing-card popular" style="overflow: visible;">
                    <div class="badge-popular">En Popüler</div>
                    <div class="card-body p-4 p-lg-5 bg-white rounded-4">
                        <h5 class="fw-bold text-primary mb-4">Profesyonel</h5>
                        <div class="display-6 fw-bold mb-2 text-dark">₺199<span class="fs-6 fw-normal text-muted">/ay</span></div>
                        <p class="text-muted small mb-4">En çok tercih edilen plan.</p>

                        <ul class="list-unstyled mb-4">
                             <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> <strong>Sınırsız</strong> kurs erişimi</li>
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> Ödev değerlendirme</li>
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> Öncelikli destek</li>
                            <li class="mb-3 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill text-primary"></i> Sertifika</li>
                        </ul>
                        <a href="#" class="btn btn-primary w-100 btn-pill py-2 fw-semibold shadow-sm">Hemen Başla</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>