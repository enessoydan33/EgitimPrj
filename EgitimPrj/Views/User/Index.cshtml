@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container-fluid px-3 py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-6">
            <!-- Giriş Kartı -->
            <div class="login-card glass-card rounded-4 p-4 p-md-5 shadow-lg">
                <div class="text-center mb-4">
                    <div class="login-icon mb-3">
                        <i class="bi bi-person-circle text-primary" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Hoş Geldiniz!</h2>
                    <p class="text-muted">Hesabınıza giriş yapın</p>
                </div>

                <form method="post" asp-action="Index" asp-controller="User" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control border-start-0"
                                   autocomplete="off"
                                   data-lpignore="true"
                                   data-form-type="other"
                                   placeholder="ornek@email.com" />

                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control border-start-0"
                                   autocomplete="new-password"
                                   data-lpignore="true"
                                   data-form-type="other"
                                   placeholder="Şifrenizi girin" />

                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('Password', 'passwordToggle')">
                                <i class="bi bi-eye" id="passwordToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">Beni hatırla</label>
                        </div>
                        <a href="#" class="text-decoration-none text-primary">Şifremi unuttum</a>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-gradient btn-lg btn-pill">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="text-muted mb-3">Hesabınız yok mu?</p>
                        <div class="d-flex flex-column flex-md-row justify-content-center gap-2">
                            <a asp-controller="User" asp-action="Register" class="btn btn-outline-primary btn-pill">
                                <i class="bi bi-person-plus me-2"></i>Öğrenci Olarak Kayıt Ol
                            </a>
                            <a asp-controller="Teacher" asp-action="Login" class="btn btn-outline-secondary btn-pill">
                                <i class="bi bi-mortarboard me-2"></i>Öğretmen Olarak Giriş Yap
                            </a>
                            <a asp-controller="Teacher" asp-action="Register" class="btn btn-outline-secondary btn-pill">
                                <i class="bi bi-mortarboard-fill me-2"></i>Öğretmen Olarak Kayıt Ol
                            </a>
                        </div>
                    </div>
                </form>

                <!-- Sosyal Medya Girişi -->
                <div class="mt-4">
                    <div class="text-center mb-3">
                        <span class="text-muted">veya</span>
                    </div>
                    <div class="row g-2">
                        <div class="mb-3 text-center">
                            <button class="btn btn-outline-danger w-50 btn-pill">
                                <i class="bi bi-google me-2"></i>Google
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    @* togglePassword artık global: wwwroot/js/site.js *@
}
