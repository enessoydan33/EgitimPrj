@using EgitimPrj.Models.ViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}
@model RegisterViewModel

<div class="container-fluid px-3 py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-6">
            <!-- Kayıt Ol Kartı -->
            <div class="register-card glass-card rounded-4 p-4 p-md-5 shadow-lg">
                <div class="text-center mb-4">
                    <div class="register-icon mb-3">
                        <i class="bi bi-person-plus-circle text-primary" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Hesap Oluştur</h2>
                    <p class="text-muted">Yeni hesabınızı oluşturun</p>
                </div>

                <form asp-action="Register" asp-controller="User" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-person text-muted"></i>
                                </span>
                                <input asp-for="Name" type="text" class="form-control border-start-0" placeholder="Adınız" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="SurName" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-person text-muted"></i>
                                </span>
                                <input asp-for="SurName" type="text" class="form-control border-start-0" placeholder="Soyadınız" />
                            </div>
                            <span asp-validation-for="SurName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Email" type="email" class="form-control border-start-0" placeholder="ornek@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                   

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Şifrenizi girin" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('Password','passwordToggle')">
                                <i class="bi bi-eye" id="passwordToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock-fill text-muted"></i>
                            </span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0" placeholder="Şifrenizi tekrar girin" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('ConfirmPassword','ConfirmpasswordToggle')">
                                   <i class="bi bi-eye" id="ConfirmpasswordToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <hr class="my-4 text-muted opacity-25" />
                    <div class="mb-2">
                        <h3 class="h6 fw-semibold text-dark mb-1">
                            <i class="bi bi-people me-2 text-primary"></i>Veli paneli <span class="text-muted fw-normal">(isteğe bağlı)</span>
                        </h3>
                        <p class="text-muted small mb-0">
                            Doldurursanız veli, öğrenciyle ilişkilendirilmiş ayrı bir hesapla giriş yapabilir. Boş bırakabilirsiniz.
                        </p>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="ParentName" class="form-label fw-semibold"></label>
                            <input asp-for="ParentName" type="text" class="form-control" placeholder="Veli adı" autocomplete="off" />
                            <span asp-validation-for="ParentName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ParentSurname" class="form-label fw-semibold"></label>
                            <input asp-for="ParentSurname" type="text" class="form-control" placeholder="Veli soyadı" autocomplete="off" />
                            <span asp-validation-for="ParentSurname" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentEmail" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="ParentEmail" type="email" class="form-control border-start-0" placeholder="veli@email.com" autocomplete="off" />
                        </div>
                        <span asp-validation-for="ParentEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="ParentPassword" type="password" class="form-control border-start-0" placeholder="Veli paneli şifresi" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('ParentPassword','parentRegPasswordToggle')">
                                <i class="bi bi-eye" id="parentRegPasswordToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ParentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ParentConfirmPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock-fill text-muted"></i>
                            </span>
                            <input asp-for="ParentConfirmPassword" type="password" class="form-control border-start-0" placeholder="Veli şifresi tekrar" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePassword('ParentConfirmPassword','parentRegPasswordConfirmToggle')">
                                <i class="bi bi-eye" id="parentRegPasswordConfirmToggle"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ParentConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="AcceptTerms" class="form-check-input" />
                            <label asp-for="AcceptTerms" class="form-check-label">
                                <a href="#" class="text-decoration-none text-primary">Kullanım Şartları</a> ve
                                <a href="#" class="text-decoration-none text-primary">Gizlilik Politikası</a>'nı kabul ediyorum
                            </label>
                        </div>
                        <span asp-validation-for="AcceptTerms" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input type="checkbox"  class="form-check-input" />
                            <label type="check-box" class="form-check-label">
                                E-posta ile güncellemeleri almak istiyorum
                            </label>
                        </div>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-gradient btn-lg btn-pill">
                            <i class="bi bi-person-plus me-2"></i>Hesap Oluştur
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="text-muted mb-3">Zaten hesabınız var mı?</p>
                        <div class="d-flex flex-column flex-md-row justify-content-center gap-2">
                            <a asp-controller="User" asp-action="Index" class="btn btn-outline-primary btn-pill">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Öğrenci Girişi
                            </a>
                            <a asp-controller="Teacher" asp-action="Login" class="btn btn-outline-secondary btn-pill">
                                <i class="bi bi-mortarboard me-2"></i>Öğretmen Girişi
                            </a>
                            <a asp-controller="Teacher" asp-action="Register" class="btn btn-outline-secondary btn-pill">
                                <i class="bi bi-mortarboard-fill me-2"></i>Öğretmen Kayıt
                            </a>
                        </div>
                    </div>
                </form>

                <!-- Sosyal Medya Kayıt -->
                <div class="mt-4">
                    <div class="text-center mb-3">
                        <span class="text-muted">veya</span>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <button class="btn btn-outline-danger w-100 btn-pill">
                                <i class="bi bi-google me-2"></i>Google
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-primary w-100 btn-pill">
                                <i class="bi bi-facebook me-2"></i>Facebook
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    @* togglePassword artık global: wwwroot/js/site.js *@
}
